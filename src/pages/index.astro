<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Official website and EPK for Itchy Lemon — Portuguese DJ and electronic music producer focused on melodic, deep and underground electronic music."
    />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Itchy Lemon | Official Website & EPK</title>

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href="https://itchy-lemon.pages.dev/" />

    <meta property="og:title" content="Itchy Lemon | Official Website & EPK" />
    <meta
      property="og:description"
      content="Melodic electronic music with deep groove, emotional tension and dancefloor instinct."
    />
    <meta property="og:image" content="https://itchy-lemon.pages.dev/og-image.png" />
    <meta property="og:url" content="https://itchy-lemon.pages.dev/" />
    <meta property="og:type" content="website" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Itchy Lemon | Official Website & EPK" />
    <meta
      name="twitter:description"
      content="Melodic electronic music with deep groove, emotional tension and dancefloor instinct."
    />
    <meta name="twitter:image" content="https://itchy-lemon.pages.dev/og-image.png" />

    <style>
      :root {
        --bg: #07090c;
        --bg-soft: #0f1318;
        --text: #f4f4f0;
        --muted: #a8adb4;
        --acid: #d8ff3e;
        --line: rgba(244, 244, 240, 0.14);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: Arial, Helvetica, sans-serif;
        background:
          radial-gradient(circle at 78% 18%, rgba(216, 255, 62, 0.14), transparent 28%),
          radial-gradient(circle at 15% 85%, rgba(216, 255, 62, 0.08), transparent 30%),
          var(--bg);
        color: var(--text);
        min-height: 100vh;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .page {
        width: min(1120px, calc(100% - 40px));
        margin: 0 auto;
        padding: 28px 0 56px;
      }

      header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        padding: 18px 0;
        border-bottom: 1px solid var(--line);
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 14px;
        font-weight: 800;
        letter-spacing: 0.16em;
        text-transform: uppercase;
      }

      .brand-mark {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: var(--acid);
        box-shadow: 0 0 28px rgba(216, 255, 62, 0.28);
      }

      nav {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: 16px;
        font-size: 13px;
        color: var(--muted);
      }

      nav a:hover {
        color: var(--acid);
      }

      main {
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 48px;
        align-items: center;
        padding: 88px 0 72px;
      }

      .eyebrow {
        margin: 0 0 18px;
        color: var(--acid);
        font-size: 13px;
        font-weight: 800;
        letter-spacing: 0.22em;
        text-transform: uppercase;
      }

      h1 {
        margin: 0;
        font-size: clamp(64px, 11vw, 132px);
        line-height: 0.86;
        letter-spacing: -0.08em;
        text-transform: uppercase;
      }

      .subtitle {
        max-width: 720px;
        margin: 28px 0 0;
        color: var(--text);
        font-size: clamp(22px, 3vw, 34px);
        line-height: 1.18;
        font-weight: 700;
        letter-spacing: -0.04em;
      }

      .intro {
        max-width: 650px;
        margin: 22px 0 0;
        color: var(--muted);
        font-size: 17px;
        line-height: 1.65;
      }

      .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        margin-top: 34px;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 46px;
        padding: 0 22px;
        border-radius: 999px;
        border: 1px solid var(--line);
        font-size: 13px;
        font-weight: 800;
        letter-spacing: 0.1em;
        text-transform: uppercase;
      }

      .button.primary {
        background: var(--acid);
        border-color: var(--acid);
        color: var(--bg);
      }

      .button:hover {
        border-color: var(--acid);
        transform: translateY(-1px);
      }

      .visual-card {
        position: relative;
        overflow: hidden;
        min-height: 460px;
        padding: 34px;
        border: 1px solid var(--line);
        border-radius: 34px;
        background:
          linear-gradient(145deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.02)),
          rgba(15, 19, 24, 0.72);
        box-shadow: 0 30px 90px rgba(0, 0, 0, 0.32);
      }

      .visual-card::before {
        content: "";
        position: absolute;
        width: 260px;
        height: 260px;
        top: 42px;
        right: -45px;
        border-radius: 50%;
        background: var(--acid);
        opacity: 0.94;
      }

      .visual-card::after {
        content: "";
        position: absolute;
        width: 74px;
        height: 74px;
        top: 86px;
        right: 74px;
        border-radius: 50%;
        background: var(--text);
        opacity: 0.85;
      }

      .card-content {
        position: relative;
        z-index: 2;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        min-height: 392px;
      }

      .card-label {
        color: var(--acid);
        font-size: 12px;
        font-weight: 800;
        letter-spacing: 0.2em;
        text-transform: uppercase;
      }

      .card-title {
        max-width: 340px;
        margin: 14px 0 0;
        font-size: 38px;
        line-height: 1;
        letter-spacing: -0.06em;
        text-transform: uppercase;
      }

      .card-text {
        max-width: 360px;
        margin: 20px 0 0;
        color: var(--muted);
        line-height: 1.6;
      }

      .stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
        margin-top: 28px;
      }

      .stat {
        padding: 14px;
        border: 1px solid var(--line);
        border-radius: 18px;
        background: rgba(7, 9, 12, 0.42);
      }

      .stat strong {
        display: block;
        color: var(--acid);
        font-size: 20px;
      }

      .stat span {
        display: block;
        margin-top: 4px;
        color: var(--muted);
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.12em;
      }

      .quick-links {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 14px;
        padding-top: 26px;
        border-top: 1px solid var(--line);
      }

      .quick-links a {
        padding: 18px;
        border: 1px solid var(--line);
        border-radius: 22px;
        background: rgba(255, 255, 255, 0.03);
        color: var(--muted);
        font-size: 13px;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .quick-links a:hover {
        color: var(--bg);
        background: var(--acid);
        border-color: var(--acid);
      }

      @media (max-width: 820px) {
        header {
          align-items: flex-start;
          flex-direction: column;
        }

        nav {
          justify-content: flex-start;
        }

        main {
          grid-template-columns: 1fr;
          gap: 32px;
          padding: 56px 0 48px;
        }

        .visual-card {
          min-height: 390px;
        }

        .card-content {
          min-height: 320px;
        }

        .quick-links {
          grid-template-columns: repeat(2, 1fr);
        }
      }

      @media (max-width: 520px) {
        .page {
          width: min(100% - 28px, 1120px);
        }

        nav {
          gap: 12px;
          font-size: 12px;
        }

        h1 {
          font-size: 62px;
        }

        .subtitle {
          font-size: 23px;
        }

        .stats {
          grid-template-columns: 1fr;
        }

        .quick-links {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>

  <body>
    <div class="page">
      <header>
        <a class="brand" href="/" aria-label="Itchy Lemon homepage">
          <span class="brand-mark" aria-hidden="true"></span>
          <span>Itchy Lemon</span>
        </a>

        <nav aria-label="Main navigation">
          <a href="/music">Music</a>
          <a href="/bio">Bio</a>
          <a href="/discography">Discography</a>
          <a href="/press-kit">Press Kit</a>
          <a href="/booking">Booking</a>
        </nav>
      </header>

      <main>
        <section>
          <p class="eyebrow">Official Website & EPK</p>
          <h1>Itchy Lemon</h1>

          <p class="subtitle">
            Melodic electronic music with deep groove, emotional tension and
            dancefloor instinct.
          </p>

          <p class="intro">
            Selected DJ sets, original productions and official artist links —
            built around melodic tension, deep groove and underground electronic
            energy.
          </p>

          <div class="actions">
            <a class="button primary" href="/music">Listen</a>
            <a class="button" href="/booking">Book Itchy Lemon</a>
            <a class="button" href="/press-kit">Press Kit</a>
          </div>
        </section>

        <aside class="visual-card" aria-label="Artist profile">
          <div class="card-content">
            <p class="card-label">Artist Profile</p>
            <h2 class="card-title">Melodic · Deep · Underground</h2>
            <p class="card-text">
              A Portuguese DJ and producer project focused on atmosphere,
              rhythm and emotional progression.
            </p>

            <div class="stats">
              <div class="stat">
                <strong>DJ</strong>
                <span>Sets</span>
              </div>
              <div class="stat">
                <strong>Producer</strong>
                <span>Music</span>
              </div>
              <div class="stat">
                <strong>EPK</strong>
                <span>Ready</span>
              </div>
            </div>
          </div>
        </aside>
      </main>

      <section class="quick-links" aria-label="Official links">
        <a href="https://open.spotify.com/artist/5IfFyzIiz1iBO7RZUJyFen" target="_blank" rel="noreferrer">Spotify</a>
        <a href="https://www.instagram.com/itchy_lemon/" target="_blank" rel="noreferrer">Instagram</a>
        <a href="https://www.youtube.com/@ItchyLemonTV" target="_blank" rel="noreferrer">YouTube</a>
        <a href="https://www.beatport.com/artist/itchy-lemon/339277" target="_blank" rel="noreferrer">Beatport</a>
      </section>
    </div>
  </body>
</html>