<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Official website and EPK for Itchy Lemon — Portuguese DJ and electronic music producer focused on melodic, deep and underground electronic music."
    />
    <meta name="author" content="Itchy Lemon" />
    <meta name="theme-color" content="#07090c" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Itchy Lemon | Official Website & EPK</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href="https://itchylemon.com/" />

    <meta property="og:title" content="Itchy Lemon | Official Website & EPK" />
    <meta
      property="og:description"
      content="Melodic electronic music with deep groove, emotional tension and dancefloor instinct."
    />
    <meta property="og:image" content="https://itchylemon.com/og-image.png" />
    <meta property="og:url" content="https://itchylemon.com/" />
    <meta property="og:type" content="website" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Itchy Lemon | Official Website & EPK" />
    <meta
      name="twitter:description"
      content="Melodic electronic music with deep groove, emotional tension and dancefloor instinct."
    />
    <meta name="twitter:image" content="https://itchylemon.com/og-image.png" />

    <style>
      :root {
        --bg: #07090c;
        --bg-soft: #10141b;
        --text: #f4f4f0;
        --muted: #a7adb8;
        --acid: #d8ff3e;
        --line: rgba(255, 255, 255, 0.12);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: Arial, Helvetica, sans-serif;
        background:
          radial-gradient(circle at top right, rgba(216, 255, 62, 0.16), transparent 32%),
          linear-gradient(135deg, #07090c 0%, #111827 48%, #050608 100%);
        color: var(--text);
        min-height: 100vh;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .page {
        min-height: 100vh;
        padding: 32px;
        display: flex;
        flex-direction: column;
      }

      header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 24px;
        padding-bottom: 32px;
      }

      .logo {
        display: flex;
        align-items: center;
        gap: 10px;
        color: var(--acid);
        font-weight: 700;
        text-transform: uppercase;
        white-space: nowrap;
      }

      .logo-icon {
        display: block;
        width: 22px;
        height: 22px;
        object-fit: contain;
        flex-shrink: 0;
      }

      .logo span {
        display: inline-block;
        font-size: 14px;
        letter-spacing: 0.32em;
        line-height: 1;
      }

      nav {
        display: flex;
        gap: 22px;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--muted);
      }

      nav a:hover {
        color: var(--acid);
      }

      main {
        flex: 1;
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        align-items: center;
        gap: 56px;
        max-width: 1180px;
        width: 100%;
        margin: 0 auto;
      }

      .eyebrow {
        color: var(--acid);
        text-transform: uppercase;
        letter-spacing: 0.24em;
        font-size: 13px;
        margin-bottom: 20px;
      }

      h1 {
        margin: 0;
        font-size: clamp(58px, 10vw, 132px);
        line-height: 0.88;
        letter-spacing: -0.07em;
        text-transform: uppercase;
      }

      .subtitle {
        margin-top: 28px;
        max-width: 680px;
        font-size: clamp(22px, 3vw, 38px);
        line-height: 1.1;
        color: var(--text);
      }

      .intro {
        margin-top: 24px;
        max-width: 640px;
        font-size: 17px;
        line-height: 1.7;
        color: var(--muted);
      }

      .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        margin-top: 36px;
      }

      .button {
        border: 1px solid var(--line);
        padding: 14px 20px;
        border-radius: 999px;
        font-size: 13px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        transition: 0.2s ease;
      }

      .button.primary {
        background: var(--acid);
        color: #050608;
        border-color: var(--acid);
        font-weight: 700;
      }

      .button:hover {
        transform: translateY(-2px);
        border-color: var(--acid);
      }

      .home-cta {
        margin-top: 28px;
        max-width: 680px;
        border: 1px solid var(--line);
        border-radius: 24px;
        background:
          linear-gradient(135deg, rgba(216, 255, 62, 0.1), transparent),
          rgba(16, 20, 27, 0.58);
        padding: 22px;
        backdrop-filter: blur(12px);
      }

      .home-cta strong {
        display: block;
        color: var(--acid);
        text-transform: uppercase;
        letter-spacing: 0.16em;
        font-size: 12px;
        margin-bottom: 10px;
      }

      .home-cta p {
        margin: 0;
        color: var(--muted);
        font-size: 15px;
        line-height: 1.7;
      }

      .quick-links {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 22px;
      }

      .quick-link {
        color: var(--muted);
        font-size: 13px;
        border-bottom: 1px solid var(--line);
        padding-bottom: 5px;
      }

      .quick-link:hover {
        color: var(--acid);
        border-color: var(--acid);
      }

      .visual-card {
        border: 1px solid var(--line);
        background: rgba(16, 20, 27, 0.72);
        border-radius: 28px;
        padding: 28px;
        min-height: 460px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        box-shadow: 0 24px 80px rgba(0, 0, 0, 0.32);
        backdrop-filter: blur(12px);
      }

      .featured-video {
        width: 100%;
        max-width: 520px;
        aspect-ratio: 16 / 9;
        margin: 8px auto 28px 0;
        border-radius: 18px;
        overflow: hidden;
        background: #050608;
        border: 1px solid var(--line);
        filter: drop-shadow(0 0 42px rgba(216, 255, 62, 0.16));
      }

      .featured-video iframe {
        width: 100%;
        height: 100%;
        border: 0;
        display: block;
      }

      .card-label {
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.18em;
        font-size: 12px;
      }

      .card-title {
        font-size: 34px;
        line-height: 1;
        letter-spacing: -0.04em;
        margin-top: 12px;
      }

      .card-copy {
        color: var(--muted);
        line-height: 1.6;
        font-size: 15px;
        margin-top: 18px;
      }

      .stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
        margin-top: 28px;
      }

      .stat {
        border-top: 1px solid var(--line);
        padding-top: 14px;
      }

      .stat strong {
        display: block;
        color: var(--acid);
        font-size: 20px;
      }

      .stat span {
        display: block;
        color: var(--muted);
        font-size: 12px;
        margin-top: 4px;
      }

      footer {
        color: var(--muted);
        font-size: 12px;
        padding-top: 32px;
        display: flex;
        justify-content: space-between;
        gap: 20px;
      }

      @media (max-width: 860px) {
        .page {
          padding: 22px;
        }

        header {
          align-items: flex-start;
          flex-direction: column;
        }

        nav {
          flex-wrap: wrap;
        }

        main {
          display: flex;
          flex-direction: column;
          gap: 36px;
        }

        .visual-card {
          min-height: 360px;
        }

        footer {
          flex-direction: column;
        }
      }
    </style>
  </head>

  <body>
    <div class="page">
      <header>
        <a class="logo" href="/" aria-label="Itchy Lemon homepage">
          <img class="logo-icon" src="/favicon.png" alt="" />
          <span>Itchy Lemon</span>
        </a>

        <nav>
          <a href="/music">Music</a>
          <a href="/bio">Bio</a>
          <a href="/discography">Discography</a>
          <a href="/media">Media</a>
          <a href="/press-kit">Press Kit</a>
          <a href="/sets">Sets</a>
          <a href="/booking">Booking</a>
        </nav>
      </header>

      <main>
        <section>
          <p class="eyebrow">Official Website & EPK</p>

          <h1>ITCHY<br />LEMON</h1>

          <p class="subtitle">
            Melodic electronic music with deep groove, emotional tension and dancefloor instinct.
          </p>

          <p class="intro">
            Selected DJ sets, original productions and official artist links — built around melodic tension, deep groove and underground electronic energy.
          </p>

          <div class="actions">
            <a class="button primary" href="/sets">Explore Sets</a>
            <a class="button" href="/booking">Book Itchy Lemon</a>
            <a class="button" href="/press-kit">Press Kit</a>
          </div>

          <div class="home-cta">
            <strong>Listen. Feel. Book.</strong>
            <p>
              From melodic club journeys to guest mixes and selected electronic music events, Itchy Lemon is available for bookings, collaborations and curated appearances.
            </p>
          </div>

          <div class="quick-links" aria-label="Featured artist links">
            <a class="quick-link" href="https://open.spotify.com/artist/5IfFyzIiz1iBO7RZUJyFen" target="_blank" rel="noreferrer">
              Spotify
            </a>

            <a class="quick-link" href="https://www.instagram.com/itchy_lemon/" target="_blank" rel="noreferrer">
              Instagram
            </a>

            <a class="quick-link" href="https://www.youtube.com/@ItchyLemonTV" target="_blank" rel="noreferrer">
              YouTube
            </a>

            <a class="quick-link" href="https://www.beatport.com/artist/itchy-lemon/339277" target="_blank" rel="noreferrer">
              Beatport
            </a>
          </div>
        </section>

        <aside class="visual-card" aria-label="Artist highlight">
          <div class="featured-video">
            <iframe
              src="https://www.youtube.com/embed/KJQfMcy3Hws?controls=1&rel=0&modestbranding=1&playsinline=1&fs=0&iv_load_policy=3"
              title="Itchy Lemon featured video"
              allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            ></iframe>
          </div>

          <div>
            <p class="card-label">Artist Profile</p>
            <div class="card-title">Melodic · Deep · Underground</div>

            <p class="card-copy">
              A Portuguese DJ and producer project focused on atmosphere, rhythm and emotional progression.
            </p>

            <div class="stats">
              <div class="stat">
                <strong>DJ</strong>
                <span>Club sets</span>
              </div>

              <div class="stat">
                <strong>Producer</strong>
                <span>Original music</span>
              </div>

              <div class="stat">
                <strong>EPK</strong>
                <span>Booking ready</span>
              </div>
            </div>
          </div>
        </aside>
      </main>

      <footer>
        <span>© 2026 Itchy Lemon. All rights reserved.</span>
        <span>Based in Portugal · Available for bookings, guest mixes and selected collaborations.</span>
      </footer>
    </div>

    <!-- Start of HubSpot Embed Code -->
    <script type="text/javascript" id="hs-script-loader" async defer src="https://js-eu1.hs-scripts.com/148590426.js"></script>
    <!-- End of HubSpot Embed Code -->
  </body>
</html>