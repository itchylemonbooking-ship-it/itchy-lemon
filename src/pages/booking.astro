<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Book Itchy Lemon for DJ sets, electronic music events, guest mixes and selected creative collaborations."
    />
    <meta name="author" content="Itchy Lemon" />
    <meta name="theme-color" content="#07090c" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Booking | Itchy Lemon</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href="https://itchy-lemon.pages.dev/booking/" />

    <style>
      :root {
        --bg: #07090c;
        --bg-soft: #10141b;
        --text: #f4f4f0;
        --muted: #a7adb8;
        --acid: #d8ff3e;
        --line: rgba(255, 255, 255, 0.12);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: Arial, Helvetica, sans-serif;
        background:
          radial-gradient(circle at top right, rgba(216, 255, 62, 0.12), transparent 34%),
          linear-gradient(135deg, #07090c 0%, #111827 48%, #050608 100%);
        color: var(--text);
        min-height: 100vh;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      button,
      input,
      select,
      textarea {
        font: inherit;
      }

      .page {
        min-height: 100vh;
        padding: 32px;
      }

      header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 24px;
        padding-bottom: 56px;
      }

      .logo {
        display: flex;
        align-items: center;
        gap: 10px;
        color: var(--acid);
        font-weight: 700;
        text-transform: uppercase;
        white-space: nowrap;
      }

      .logo-icon {
        display: block;
        width: 22px;
        height: 22px;
        object-fit: contain;
        flex-shrink: 0;
      }

      .logo span {
        display: inline-block;
        font-size: 14px;
        letter-spacing: 0.32em;
        line-height: 1;
      }

      nav {
        display: flex;
        gap: 22px;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--muted);
      }

      nav a:hover,
      nav a.active {
        color: var(--acid);
      }

      main {
        max-width: 1080px;
        margin: 0 auto;
      }

      .eyebrow {
        color: var(--acid);
        text-transform: uppercase;
        letter-spacing: 0.24em;
        font-size: 13px;
        margin-bottom: 18px;
      }

      h1 {
        margin: 0;
        font-size: clamp(48px, 8vw, 104px);
        line-height: 0.9;
        letter-spacing: -0.06em;
        text-transform: uppercase;
      }

      .lead {
        margin-top: 32px;
        max-width: 800px;
        font-size: clamp(22px, 3vw, 34px);
        line-height: 1.16;
      }

      .cta-panel {
        margin-top: 48px;
        border: 1px solid var(--line);
        border-radius: 28px;
        background:
          linear-gradient(135deg, rgba(216, 255, 62, 0.1), transparent),
          rgba(16, 20, 27, 0.72);
        padding: 28px;
        backdrop-filter: blur(12px);
      }

      .cta-panel p {
        margin: 0;
        max-width: 760px;
        color: var(--muted);
        font-size: 18px;
        line-height: 1.7;
      }

      .cta-panel strong {
        color: var(--text);
      }

      .booking-grid {
        display: grid;
        grid-template-columns: 0.9fr 1.1fr;
        gap: 28px;
        margin-top: 72px;
      }

      .panel {
        border: 1px solid var(--line);
        background: rgba(16, 20, 27, 0.72);
        border-radius: 28px;
        padding: 28px;
        backdrop-filter: blur(12px);
      }

      .panel.wide {
        grid-column: span 2;
      }

      .panel h2 {
        margin: 0 0 20px;
        color: var(--acid);
        font-size: 13px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }

      .panel p {
        color: var(--muted);
        font-size: 17px;
        line-height: 1.7;
        margin: 0 0 20px;
      }

      .services {
        display: grid;
        gap: 16px;
        margin: 0;
        padding: 0;
        list-style: none;
      }

      .services li {
        border-top: 1px solid var(--line);
        padding-top: 16px;
        color: var(--muted);
        line-height: 1.5;
      }

      .services strong {
        display: block;
        color: var(--text);
        margin-bottom: 4px;
      }

      .booking-form {
        display: grid;
        gap: 16px;
      }

      .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
      }

      .field {
        display: grid;
        gap: 8px;
      }

      .field label {
        color: var(--acid);
        text-transform: uppercase;
        letter-spacing: 0.14em;
        font-size: 11px;
      }

      .field input,
      .field select,
      .field textarea {
        width: 100%;
        border: 1px solid var(--line);
        border-radius: 18px;
        background: rgba(7, 9, 12, 0.62);
        color: var(--text);
        padding: 14px 16px;
        outline: none;
      }

      .field textarea {
        min-height: 150px;
        resize: vertical;
      }

      .field input:focus,
      .field select:focus,
      .field textarea:focus {
        border-color: var(--acid);
      }

      .form-note {
        color: var(--muted);
        font-size: 13px;
        line-height: 1.6;
      }

      .contact-link,
      .quick-link {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 24px;
        border-top: 1px solid var(--line);
        padding: 18px 0;
        color: var(--muted);
      }

      .contact-link strong,
      .quick-link strong {
        color: var(--text);
        font-size: 20px;
      }

      .contact-link span,
      .quick-link span {
        color: var(--acid);
        text-transform: uppercase;
        letter-spacing: 0.16em;
        font-size: 12px;
      }

      .contact-link:hover strong,
      .quick-link:hover strong {
        color: var(--acid);
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-top: 8px;
        background: var(--acid);
        color: #050608;
        border: 1px solid var(--acid);
        border-radius: 999px;
        padding: 15px 22px;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        cursor: pointer;
        transition:
          transform 0.2s ease,
          background 0.2s ease,
          border-color 0.2s ease;
      }

      .button:hover {
        transform: translateY(-2px);
      }

      .button-secondary {
        background: rgba(216, 255, 62, 0.06);
        color: var(--acid);
        border-color: var(--line);
      }

      .button-secondary:hover {
        border-color: var(--acid);
      }

      footer {
        max-width: 1080px;
        margin: 80px auto 0;
        color: var(--muted);
        font-size: 12px;
        padding-top: 28px;
        border-top: 1px solid var(--line);
        display: flex;
        justify-content: space-between;
        gap: 20px;
      }

      @media (max-width: 900px) {
        .booking-grid {
          grid-template-columns: 1fr;
          margin-top: 48px;
        }

        .panel.wide {
          grid-column: span 1;
        }

        .form-row {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 860px) {
        .page {
          padding: 22px;
        }

        header {
          align-items: flex-start;
          flex-direction: column;
        }

        nav {
          flex-wrap: wrap;
        }

        .contact-link,
        .quick-link {
          align-items: flex-start;
          flex-direction: column;
          gap: 8px;
        }

        footer {
          flex-direction: column;
        }
      }
    </style>
  </head>

  <body>
    <div class="page">
      <header>
        <a class="logo" href="/" aria-label="Itchy Lemon homepage">
          <img class="logo-icon" src="/favicon.png" alt="" />
          <span>Itchy Lemon</span>
        </a>

        <nav>
  <a href="/music">Music</a>
  <a href="/bio">Bio</a>
  <a href="/discography">Discography</a>
  <a href="/media">Media</a>
  <a href="/press-kit">Press Kit</a>
  <a href="/sets">Sets</a>
  <a class="active" href="/booking">Booking</a>
</nav>
      </header>

      <main>
        <p class="eyebrow">Booking & Contact</p>

        <h1>Booking</h1>

        <p class="lead">
          Book Itchy Lemon for DJ sets, electronic music events, guest mixes and selected creative collaborations.
        </p>

        <section class="cta-panel" aria-label="Booking call to action">
          <p>
            Looking for a melodic, deep and progressive electronic music journey?
            <strong>Send a booking request</strong> with the event details and availability will be confirmed as soon as possible.
          </p>
        </section>

        <section class="booking-grid">
          <article class="panel">
            <h2>Available for</h2>

            <ul class="services">
              <li>
                <strong>Club DJ sets</strong>
                Melodic, deep and progressive electronic selections for intimate rooms and dancefloor-focused events.
              </li>

              <li>
                <strong>Guest mixes</strong>
                Curated mixes for radio shows, podcasts, online platforms and music communities.
              </li>

              <li>
                <strong>Electronic music events</strong>
                Artist appearances, curated concepts and selected underground music formats.
              </li>

              <li>
                <strong>Collaborations</strong>
                Remixes, production ideas, creative projects and selected label opportunities.
              </li>
            </ul>
          </article>

          <article class="panel">
            <h2>Booking Request</h2>

            <p>
              Use this form to send the main details. Later, this can be connected directly to HubSpot.
            </p>

            <form class="booking-form" id="booking-form">
              <div class="form-row">
                <div class="field">
                  <label for="name">Name</label>
                  <input id="name" name="name" type="text" autocomplete="name" required />
                </div>

                <div class="field">
                  <label for="email">Email</label>
                  <input id="email" name="email" type="email" autocomplete="email" required />
                </div>
              </div>

              <div class="form-row">
                <div class="field">
                  <label for="event-type">Event type</label>
                  <select id="event-type" name="eventType" required>
                    <option value="">Select option</option>
                    <option>Club DJ set</option>
                    <option>Festival / electronic music event</option>
                    <option>Guest mix / radio show</option>
                    <option>Private event</option>
                    <option>Collaboration / remix</option>
                    <option>Other</option>
                  </select>
                </div>

                <div class="field">
                  <label for="event-date">Event date</label>
                  <input id="event-date" name="eventDate" type="date" />
                </div>
              </div>

              <div class="form-row">
                <div class="field">
                  <label for="location">Location / city</label>
                  <input id="location" name="location" type="text" />
                </div>

                <div class="field">
                  <label for="venue">Venue / promoter</label>
                  <input id="venue" name="venue" type="text" />
                </div>
              </div>

              <div class="field">
                <label for="budget">Budget range</label>
                <select id="budget" name="budget">
                  <option value="">Select option</option>
                  <option>To be discussed</option>
                  <option>Up to €250</option>
                  <option>€250 – €500</option>
                  <option>€500 – €1,000</option>
                  <option>€1,000+</option>
                </select>
              </div>

              <div class="field">
                <label for="message">Message</label>
                <textarea
                  id="message"
                  name="message"
                  placeholder="Tell me about the event, concept, expected audience, set duration or any relevant details."
                  required
                ></textarea>
              </div>

              <p class="form-note">
                This first version opens your email app with the booking details. HubSpot integration can be added later.
              </p>

              <button class="button" type="submit">
                Send Booking Request
              </button>
            </form>
          </article>

          <article class="panel wide">
            <h2>Direct Contact & Verification Links</h2>

            <a class="contact-link" href="mailto:itchylemon.booking@gmail.com">
              <strong>itchylemon.booking@gmail.com</strong>
              <span>Email</span>
            </a>

            <a class="contact-link" href="/press-kit">
              <strong>Press Kit</strong>
              <span>EPK</span>
            </a>

            <a class="quick-link" href="https://open.spotify.com/artist/5IfFyzIiz1iBO7RZUJyFen" target="_blank" rel="noreferrer">
              <strong>Spotify</strong>
              <span>Listen</span>
            </a>

            <a class="quick-link" href="https://www.instagram.com/itchy_lemon/" target="_blank" rel="noreferrer">
              <strong>Instagram</strong>
              <span>Follow</span>
            </a>

            <a class="quick-link" href="https://www.facebook.com/ItchyLemondjproducer" target="_blank" rel="noreferrer">
              <strong>Facebook</strong>
              <span>Follow</span>
            </a>

            <a class="quick-link" href="https://www.youtube.com/@ItchyLemonTV" target="_blank" rel="noreferrer">
              <strong>YouTube</strong>
              <span>Watch</span>
            </a>

            <a class="quick-link" href="https://www.beatport.com/artist/itchy-lemon/339277" target="_blank" rel="noreferrer">
              <strong>Beatport</strong>
              <span>Artist page</span>
            </a>

            <a class="quick-link" href="https://www.traxsource.com/artist/131494/itchy-lemon" target="_blank" rel="noreferrer">
              <strong>Traxsource</strong>
              <span>Artist page</span>
            </a>
          </article>
        </section>
      </main>

      <footer>
        <span>© 2026 Itchy Lemon. All rights reserved.</span>
        <span>Portugal · Bookings · Guest mixes · Selected collaborations</span>
      </footer>
    </div>

    <script>
      const bookingForm = document.querySelector("#booking-form");

      bookingForm?.addEventListener("submit", (event) => {
        event.preventDefault();

        const formData = new FormData(bookingForm);

        const name = formData.get("name") || "";
        const email = formData.get("email") || "";
        const eventType = formData.get("eventType") || "";
        const eventDate = formData.get("eventDate") || "";
        const location = formData.get("location") || "";
        const venue = formData.get("venue") || "";
        const budget = formData.get("budget") || "";
        const message = formData.get("message") || "";

        const subject = encodeURIComponent(`Booking Request — ${name}`);

        const body = encodeURIComponent(
`Name: ${name}
Email: ${email}
Event type: ${eventType}
Event date: ${eventDate}
Location / city: ${location}
Venue / promoter: ${venue}
Budget range: ${budget}

Message:
${message}`
        );

        window.location.href = `mailto:itchylemon.booking@gmail.com?subject=${subject}&body=${body}`;
      });
    </script>
  </body>
</html>