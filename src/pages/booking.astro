---
import GlobalMixcloudPlayer from "../components/GlobalMixcloudPlayer.astro";
import HubSpotTracking from "../components/HubSpotTracking.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Book Itchy Lemon for DJ sets, electronic music events, guest mixes and selected creative collaborations."
    />
    <meta name="author" content="Itchy Lemon" />
    <meta name="theme-color" content="#07090c" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Booking | Itchy Lemon</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href="https://itchy-lemon.pages.dev/booking/" />

    <style>
      :root {
        --bg: #07090c;
        --bg-soft: #10141b;
        --text: #f4f4f0;
        --muted: #a7adb8;
        --acid: #d8ff3e;
        --line: rgba(255, 255, 255, 0.12);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: Arial, Helvetica, sans-serif;
        background:
          radial-gradient(circle at top right, rgba(216, 255, 62, 0.12), transparent 34%),
          linear-gradient(135deg, #07090c 0%, #111827 48%, #050608 100%);
        color: var(--text);
        min-height: 100vh;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      button {
        font: inherit;
      }

      .page {
        min-height: 100vh;
        padding: 32px;
      }

      header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 24px;
        padding-bottom: 56px;
      }

      .logo {
        display: flex;
        align-items: center;
        gap: 10px;
        color: var(--acid);
        font-weight: 700;
        text-transform: uppercase;
        white-space: nowrap;
      }

      .logo-icon {
        display: block;
        width: 22px;
        height: 22px;
        object-fit: contain;
        flex-shrink: 0;
      }

      .logo span {
        display: inline-block;
        font-size: 14px;
        letter-spacing: 0.32em;
        line-height: 1;
      }

      nav {
        display: flex;
        gap: 22px;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--muted);
      }

      nav a:hover,
      nav a.active {
        color: var(--acid);
      }

      main {
        max-width: 1080px;
        margin: 0 auto;
      }

      .eyebrow {
        color: var(--acid);
        text-transform: uppercase;
        letter-spacing: 0.24em;
        font-size: 13px;
        margin-bottom: 18px;
      }

      h1 {
        margin: 0;
        font-size: clamp(48px, 8vw, 104px);
        line-height: 0.9;
        letter-spacing: -0.06em;
        text-transform: uppercase;
      }

      .lead {
        margin-top: 32px;
        max-width: 780px;
        font-size: clamp(22px, 3vw, 34px);
        line-height: 1.16;
        color: var(--text);
      }

      .cta-panel {
        margin-top: 48px;
        border: 1px solid var(--line);
        border-radius: 28px;
        background:
          linear-gradient(135deg, rgba(216, 255, 62, 0.1), transparent),
          rgba(16, 20, 27, 0.72);
        padding: 28px;
        backdrop-filter: blur(12px);
      }

      .cta-panel p {
        margin: 0;
        max-width: 760px;
        color: var(--muted);
        font-size: 18px;
        line-height: 1.7;
      }

      .cta-panel strong {
        color: var(--text);
      }

      .cta-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 24px;
      }

      .booking-grid {
        display: grid;
        grid-template-columns: 0.9fr 1.1fr;
        gap: 28px;
        margin-top: 72px;
      }

      .panel {
        border: 1px solid var(--line);
        background: rgba(16, 20, 27, 0.72);
        border-radius: 28px;
        padding: 28px;
        backdrop-filter: blur(12px);
      }

      .panel.wide {
        grid-column: span 2;
      }

      .panel h2 {
        margin: 0 0 20px;
        color: var(--acid);
        font-size: 13px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }

      .panel p {
        color: var(--muted);
        font-size: 17px;
        line-height: 1.7;
        margin: 0 0 20px;
      }

      .panel strong {
        color: var(--text);
      }

      .services {
        display: grid;
        gap: 16px;
        margin: 0;
        padding: 0;
        list-style: none;
      }

      .services li {
        border-top: 1px solid var(--line);
        padding-top: 16px;
        color: var(--muted);
        line-height: 1.5;
      }

      .services strong {
        display: block;
        color: var(--text);
        margin-bottom: 4px;
      }

      .form-note {
        color: var(--muted);
        font-size: 13px;
        line-height: 1.6;
      }

      .contact-link,
      .quick-link {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 24px;
        border-top: 1px solid var(--line);
        padding: 18px 0;
        color: var(--muted);
      }

      .contact-link strong,
      .quick-link strong {
        color: var(--text);
        font-size: 20px;
      }

      .contact-link span,
      .quick-link span {
        color: var(--acid);
        text-transform: uppercase;
        letter-spacing: 0.16em;
        font-size: 12px;
      }

      .contact-link:hover strong,
      .quick-link:hover strong {
        color: var(--acid);
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 48px;
        padding: 0 22px;
        border-radius: 999px;
        border: 1px solid var(--line);
        background: transparent;
        color: var(--text);
        font-size: 13px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        white-space: nowrap;
        cursor: pointer;
        transition:
          transform 0.2s ease,
          background 0.2s ease,
          border-color 0.2s ease,
          color 0.2s ease;
      }

      .button.primary {
        background: var(--acid);
        color: #050608;
        border-color: var(--acid);
      }

      .button.secondary {
        background: rgba(216, 255, 62, 0.06);
        color: var(--acid);
        border-color: var(--line);
      }

      .button:hover {
        transform: translateY(-2px);
        border-color: var(--acid);
      }

      .booking-modal {
        position: fixed;
        inset: 0;
        z-index: 2000;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 28px;
        background: rgba(0, 0, 0, 0.72);
        backdrop-filter: blur(12px);
      }

      .booking-modal.is-open {
        display: flex;
      }

      .booking-modal-content {
        position: relative;
        width: min(760px, 96vw);
        max-height: 92vh;
        overflow-y: auto;
        border: 1px solid rgba(216, 255, 62, 0.18);
        border-radius: 32px;
        background:
          radial-gradient(circle at top right, rgba(216, 255, 62, 0.14), transparent 34%),
          rgba(7, 9, 12, 0.96);
        padding: clamp(24px, 5vw, 42px);
        box-shadow: 0 24px 90px rgba(0, 0, 0, 0.6);
        backdrop-filter: blur(16px);
      }

      .booking-modal-label {
        margin: 0 0 16px;
        color: var(--acid);
        text-transform: uppercase;
        letter-spacing: 0.22em;
        font-size: 12px;
      }

      .booking-modal-title {
        margin: 0;
        font-size: clamp(36px, 6vw, 68px);
        line-height: 0.92;
        letter-spacing: -0.06em;
        text-transform: uppercase;
      }

      .booking-modal-copy {
        margin: 22px 0 0;
        color: rgba(244, 244, 240, 0.76);
        font-size: 17px;
        line-height: 1.7;
        max-width: 620px;
      }

      .booking-modal-form {
        margin-top: 28px;
        border: 1px solid rgba(216, 255, 62, 0.22);
        border-radius: 24px;
        background: #ffffff;
        padding: 22px;
        overflow: hidden;
      }

      .booking-modal-form iframe {
        width: 100%;
        background: #ffffff;
        border: 0;
      }

      .booking-modal-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 28px;
      }

      .booking-modal-close {
        position: absolute;
        top: 18px;
        right: 18px;
        width: 42px;
        height: 42px;
        border: 1px solid rgba(244, 244, 240, 0.14);
        border-radius: 999px;
        background: rgba(16, 20, 27, 0.9);
        color: var(--acid);
        cursor: pointer;
        font-size: 22px;
        line-height: 1;
      }

      .booking-modal-close:hover {
        border-color: var(--acid);
      }

      footer {
        max-width: 1080px;
        margin: 80px auto 0;
        color: var(--muted);
        font-size: 12px;
        padding-top: 28px;
        border-top: 1px solid var(--line);
        display: flex;
        justify-content: space-between;
        gap: 20px;
      }

      @media (max-width: 900px) {
        .booking-grid {
          grid-template-columns: 1fr;
          margin-top: 48px;
        }

        .panel.wide {
          grid-column: span 1;
        }
      }

      @media (max-width: 860px) {
        .page {
          padding: 22px;
        }

        header {
          align-items: flex-start;
          flex-direction: column;
        }

        nav {
          flex-wrap: wrap;
        }

        .contact-link,
        .quick-link {
          align-items: flex-start;
          flex-direction: column;
          gap: 8px;
        }

        .button {
          width: 100%;
        }

        .booking-modal {
          padding: 16px;
        }

        .booking-modal-content {
          border-radius: 24px;
        }

        .booking-modal-actions {
          flex-direction: column;
        }

        footer {
          flex-direction: column;
        }
      }
    </style>
  </head>

  <body>
    <div class="page">
      <header>
        <a class="logo" href="/" aria-label="Itchy Lemon homepage">
          <img class="logo-icon" src="/favicon.png" alt="" />
          <span>Itchy Lemon</span>
        </a>

        <nav>
          <a href="/music">Music</a>
          <a href="/bio">Bio</a>
          <a href="/discography">Discography</a>
          <a href="/media">Media</a>
          <a href="/press-kit">Press Kit</a>
          <a href="/sets">Sets</a>
          <a class="active" href="/booking">Booking</a>
        </nav>
      </header>

      <main>
        <p class="eyebrow">Booking & Contact</p>

        <h1>Booking</h1>

        <p class="lead">
          Book Itchy Lemon for DJ sets, electronic music events, guest mixes and selected creative collaborations.
        </p>

        <section class="cta-panel" aria-label="Booking call to action">
          <p>
            Looking for a melodic, deep and progressive electronic music journey?
            <strong>Send a booking request</strong> with the event details and availability will be confirmed as soon as possible.
          </p>

          <div class="cta-actions">
            <button class="button primary" type="button" data-open-booking-modal>
              Check Availability
            </button>

            <a class="button secondary" href="/press-kit">
              View Press Kit
            </a>
          </div>
        </section>

        <section class="booking-grid">
          <article class="panel">
            <h2>Available for</h2>

            <ul class="services">
              <li>
                <strong>Club DJ sets</strong>
                Melodic, deep and progressive electronic selections for intimate rooms and dancefloor-focused events.
              </li>

              <li>
                <strong>Guest mixes</strong>
                Curated mixes for radio shows, podcasts, online platforms and music communities.
              </li>

              <li>
                <strong>Electronic music events</strong>
                Artist appearances, curated concepts and selected underground music formats.
              </li>

              <li>
                <strong>Collaborations</strong>
                Remixes, production ideas, creative projects and selected label opportunities.
              </li>
            </ul>
          </article>

          <article class="panel">
            <h2>Booking Request</h2>

            <p>
              Send the main booking details through the form. Your request will be reviewed and followed up according to the event context, location and availability.
            </p>

            <p>
              Use the booking form for DJ sets, electronic music events, guest mixes, radio shows and selected collaborations.
            </p>

            <p class="form-note">
              Please include event date, location, expected attendance, budget range and any relevant details in your message.
            </p>

            <button class="button primary" type="button" data-open-booking-modal>
              Book Now
            </button>
          </article>

          <article class="panel wide">
            <h2>Direct Contact & Verification Links</h2>

            <a class="contact-link" href="mailto:itchylemon.booking@gmail.com">
              <strong>itchylemon.booking@gmail.com</strong>
              <span>Email</span>
            </a>

            <a class="contact-link" href="/press-kit">
              <strong>Press Kit</strong>
              <span>EPK</span>
            </a>

            <a class="quick-link" href="https://open.spotify.com/artist/5IfFyzIiz1iBO7RZUJyFen" target="_blank" rel="noreferrer">
              <strong>Spotify</strong>
              <span>Listen</span>
            </a>

            <a class="quick-link" href="https://www.mixcloud.com/ITCHY_LEMON_DjProducer/" target="_blank" rel="noreferrer">
              <strong>Mixcloud</strong>
              <span>Sets</span>
            </a>

            <a class="quick-link" href="https://www.instagram.com/itchy_lemon/" target="_blank" rel="noreferrer">
              <strong>Instagram</strong>
              <span>Follow</span>
            </a>

            <a class="quick-link" href="https://www.facebook.com/ItchyLemondjproducer" target="_blank" rel="noreferrer">
              <strong>Facebook</strong>
              <span>Follow</span>
            </a>

            <a class="quick-link" href="https://www.youtube.com/@ItchyLemonTV" target="_blank" rel="noreferrer">
              <strong>YouTube</strong>
              <span>Watch</span>
            </a>

            <a class="quick-link" href="https://www.beatport.com/artist/itchy-lemon/339277" target="_blank" rel="noreferrer">
              <strong>Beatport</strong>
              <span>Artist page</span>
            </a>

            <a class="quick-link" href="https://www.traxsource.com/artist/131494/itchy-lemon" target="_blank" rel="noreferrer">
              <strong>Traxsource</strong>
              <span>Artist page</span>
            </a>
          </article>
        </section>
      </main>

      <footer>
        <span>© 2026 Itchy Lemon. All rights reserved.</span>
        <span>
          Portugal · Bookings · Guest mixes · Selected collaborations ·
          <a href="/privacy-policy">Privacy Policy</a>
        </span>
      </footer>
    </div>

    <div class="booking-modal" data-booking-modal aria-hidden="true">
      <div class="booking-modal-content" role="dialog" aria-modal="true" aria-label="Request Itchy Lemon Booking">
        <button class="booking-modal-close" type="button" data-close-booking-modal aria-label="Close booking popup">
          ×
        </button>

        <p class="booking-modal-label">Booking Request</p>

        <h2 class="booking-modal-title">
          Request<br />Booking
        </h2>

        <p class="booking-modal-copy">
          Send your event details, booking type, location and relevant context. Your request will be reviewed and followed up as soon as possible.
        </p>

        <div class="booking-modal-form">
          <div
            class="hs-form-frame"
            data-region="eu1"
            data-form-id="06399ad4-ccd6-4cfa-a1a0-9b7eb2d587a2"
            data-portal-id="148590426"
          ></div>
        </div>

        <div class="booking-modal-actions">
          <a class="button secondary" href="/press-kit">
            View Press Kit
          </a>

          <a class="button secondary" href="mailto:itchylemon.booking@gmail.com">
            Email Directly
          </a>
        </div>
      </div>
    </div>

    <GlobalMixcloudPlayer />
    <HubSpotTracking />

    <script src="https://js-eu1.hsforms.net/forms/embed/148590426.js" defer></script>

    <script>
      const bookingModal = document.querySelector("[data-booking-modal]");
      const bookingModalTriggers = document.querySelectorAll("[data-open-booking-modal]");
      const bookingModalClose = document.querySelector("[data-close-booking-modal]");

      const openBookingModal = () => {
        bookingModal.classList.add("is-open");
        bookingModal.setAttribute("aria-hidden", "false");
        document.body.style.overflow = "hidden";
      };

      const closeBookingModal = () => {
        bookingModal.classList.remove("is-open");
        bookingModal.setAttribute("aria-hidden", "true");
        document.body.style.overflow = "";
      };

      bookingModalTriggers.forEach((trigger) => {
        trigger.addEventListener("click", (event) => {
          event.preventDefault();
          openBookingModal();
        });
      });

      bookingModalClose?.addEventListener("click", closeBookingModal);

      bookingModal?.addEventListener("click", (event) => {
        if (event.target === bookingModal) {
          closeBookingModal();
        }
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && bookingModal.classList.contains("is-open")) {
          closeBookingModal();
        }
      });
    </script>
  </body>
</html>