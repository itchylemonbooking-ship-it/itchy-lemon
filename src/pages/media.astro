---
const title = "Media | Itchy Lemon";
const description =
  "Media gallery for Itchy Lemon — photos, flyers, visual archive and selected artist materials.";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Itchy Lemon" />
    <meta name="theme-color" content="#0a0d12" />

    <link rel="canonical" href="https://itchy-lemon.pages.dev/media" />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://itchy-lemon.pages.dev/media" />
    <meta property="og:image" content="https://itchy-lemon.pages.dev/og-image.png" />

    <style>
      :root {
        --bg: #0a0d12;
        --text: #f4f4f0;
        --muted: #a7adb8;
        --acid: #d8ff3e;
        --line: rgba(255, 255, 255, 0.12);
        --card: rgba(16, 20, 27, 0.72);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
        color: var(--text);
        background:
          radial-gradient(circle at 20% 15%, rgba(216, 255, 62, 0.12), transparent 30%),
          radial-gradient(circle at 80% 20%, rgba(255, 255, 255, 0.07), transparent 26%),
          var(--bg);
      }

      .page {
        width: min(1120px, calc(100% - 48px));
        margin: 0 auto;
        padding: 28px 0 42px;
      }

      header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        margin-bottom: 72px;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        color: var(--acid);
        text-decoration: none;
        font-size: 0.8rem;
        font-weight: 800;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }

      .brand img {
        width: 22px;
        height: 22px;
        display: block;
        object-fit: contain;
      }

      nav {
        display: flex;
        gap: 18px;
        align-items: center;
      }

      nav a {
        color: var(--muted);
        text-decoration: none;
        font-size: 0.78rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }

      nav a:hover,
      nav a.active {
        color: var(--acid);
      }

      main {
        display: grid;
        grid-template-columns: 1fr 0.86fr;
        gap: 56px;
        align-items: start;
      }

      .eyebrow {
        margin: 0 0 18px;
        color: var(--acid);
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0.22em;
        text-transform: uppercase;
      }

      h1 {
        margin: 0;
        font-size: clamp(3.6rem, 10vw, 7.8rem);
        line-height: 0.88;
        letter-spacing: -0.08em;
        text-transform: uppercase;
      }

      .lead {
        max-width: 680px;
        margin: 28px 0 0;
        color: var(--muted);
        font-size: clamp(1.05rem, 2vw, 1.28rem);
        line-height: 1.6;
      }

      .card {
        border: 1px solid var(--line);
        background: var(--card);
        border-radius: 28px;
        padding: 28px;
        backdrop-filter: blur(18px);
      }

      .card h2 {
        margin: 0 0 14px;
        color: var(--acid);
        font-size: 0.82rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
      }

      .card p {
        margin: 0;
        color: var(--muted);
        line-height: 1.7;
      }

      .stack {
        display: grid;
        gap: 18px;
      }

      .tile {
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.04);
        border-radius: 22px;
        padding: 22px;
      }

      .tile strong {
        display: block;
        margin-bottom: 8px;
        color: var(--acid);
        font-size: 0.78rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
      }

      .tile span {
        color: var(--muted);
        font-size: 0.95rem;
        line-height: 1.55;
      }

      footer {
        display: flex;
        justify-content: space-between;
        gap: 18px;
        margin-top: 74px;
        padding-top: 22px;
        border-top: 1px solid var(--line);
        color: var(--muted);
        font-size: 0.82rem;
      }

      footer a {
        color: var(--muted);
        text-decoration: none;
      }

      footer a:hover {
        color: var(--acid);
      }

      @media (max-width: 860px) {
        .page {
          width: min(100% - 32px, 1120px);
          padding-top: 22px;
        }

        header {
          align-items: flex-start;
          flex-direction: column;
          margin-bottom: 54px;
        }

        nav {
          flex-wrap: wrap;
        }

        main {
          grid-template-columns: 1fr;
          gap: 32px;
        }

        footer {
          flex-direction: column;
        }
      }
    </style>
  </head>

  <body>
    <div class="page">
      <header>
        <a class="brand" href="/">
          <img src="/favicon.png" alt="Itchy Lemon logo" />
          <span>Itchy Lemon</span>
        </a>

        <nav>
          <a href="/music">Music</a>
          <a href="/bio">Bio</a>
          <a href="/discography">Discography</a>
          <a class="active" href="/media">Media</a>
          <a href="/press-kit">Press Kit</a>
          <a href="/booking">Booking</a>
        </nav>
      </header>

      <main>
        <section>
          <p class="eyebrow">Visual Archive</p>
          <h1>Media</h1>
          <p class="lead">
            Photos, flyers, visual archive and selected materials from the Itchy Lemon project.
          </p>
        </section>

        <section class="stack" aria-label="Media categories">
          <div class="card">
            <h2>Media Gallery</h2>
            <p>
              A dedicated space for artist visuals, event materials and press-ready media.
              More assets will be added gradually.
            </p>
          </div>

          <div class="tile">
            <strong>Photos</strong>
            <span>Artist images, portraits and event-related photography.</span>
          </div>

          <div class="tile">
            <strong>Flyers</strong>
            <span>Selected event flyers, announcements and club materials.</span>
          </div>

          <div class="tile">
            <strong>Visual Assets</strong>
            <span>Press-ready images and official visual material for promoters.</span>
          </div>
        </section>
      </main>

      <footer>
        <span>© Itchy Lemon</span>
        <a href="mailto:itchylemon.booking@gmail.com">itchylemon.booking@gmail.com</a>
      </footer>
    </div>
  </body>
</html>