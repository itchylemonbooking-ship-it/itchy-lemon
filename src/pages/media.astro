<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Media gallery for Itchy Lemon — photos, flyers, visual archive and selected artist materials."
    />
    <meta name="author" content="Itchy Lemon" />
    <meta name="theme-color" content="#07090c" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Media | Itchy Lemon</title>

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href="https://itchy-lemon.pages.dev/media/" />

    <style>
      :root {
        --bg: #07090c;
        --bg-soft: #10141b;
        --text: #f4f4f0;
        --muted: #a7adb8;
        --acid: #d8ff3e;
        --line: rgba(255, 255, 255, 0.12);
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: Arial, Helvetica, sans-serif;
        background:
          radial-gradient(circle at top right, rgba(216, 255, 62, 0.12), transparent 34%),
          linear-gradient(135deg, #07090c 0%, #111827 48%, #050608 100%);
        color: var(--text);
        min-height: 100vh;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      button {
        font: inherit;
      }

      img {
        max-width: 100%;
      }

      .page {
        min-height: 100vh;
        padding: 32px;
      }

      header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 24px;
        padding-bottom: 56px;
      }

      .logo {
        display: flex;
        align-items: center;
        gap: 10px;
        color: var(--acid);
        font-weight: 700;
        text-transform: uppercase;
        white-space: nowrap;
      }

      .logo-icon {
        display: block;
        width: 22px;
        height: 22px;
        object-fit: contain;
        flex-shrink: 0;
      }

      .logo span {
        display: inline-block;
        font-size: 14px;
        letter-spacing: 0.32em;
        line-height: 1;
      }

      nav {
        display: flex;
        gap: 22px;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--muted);
      }

      nav a {
        transition: color 0.2s ease;
      }

      nav a:hover,
      nav a.active {
        color: var(--acid);
      }

      main {
        max-width: 1080px;
        margin: 0 auto;
      }

      .eyebrow {
        color: var(--acid);
        text-transform: uppercase;
        letter-spacing: 0.24em;
        font-size: 13px;
        margin: 0 0 18px;
      }

      h1 {
        margin: 0;
        font-size: clamp(48px, 8vw, 104px);
        line-height: 0.9;
        letter-spacing: -0.06em;
        text-transform: uppercase;
      }

      .lead {
        margin: 32px 0 0;
        max-width: 840px;
        font-size: clamp(22px, 3vw, 34px);
        line-height: 1.16;
        color: var(--text);
      }

      .hero-image {
        margin-top: 56px;
        border: 1px solid var(--line);
        border-radius: 28px;
        overflow: hidden;
        background:
          linear-gradient(135deg, rgba(216, 255, 62, 0.08), transparent),
          rgba(16, 20, 27, 0.72);
        box-shadow: 0 24px 80px rgba(0, 0, 0, 0.32);
      }

      .hero-trigger {
        display: block;
        width: 100%;
        padding: 0;
        border: 0;
        background: transparent;
        cursor: pointer;
      }

      .hero-image img {
        display: block;
        width: 100%;
        height: auto;
        transition:
          transform 0.25s ease,
          opacity 0.25s ease;
      }

      .hero-trigger:hover img {
        transform: scale(1.02);
        opacity: 0.9;
      }

      .section-title {
        margin: 72px 0 22px;
        color: var(--acid);
        font-size: 13px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }

      .media-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 22px;
      }

      .media-card {
        border: 1px solid var(--line);
        background: rgba(16, 20, 27, 0.72);
        border-radius: 28px;
        padding: 24px;
        min-height: 220px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        backdrop-filter: blur(12px);
      }

      .media-card h2 {
        margin: 0;
        font-size: 28px;
        line-height: 1;
        letter-spacing: -0.04em;
      }

      .media-card p {
        margin: 18px 0 0;
        color: var(--muted);
        font-size: 15px;
        line-height: 1.6;
      }

      .card-label {
        color: var(--acid);
        text-transform: uppercase;
        letter-spacing: 0.18em;
        font-size: 12px;
        margin: 0 0 18px;
      }

      .carousel {
        margin-top: 22px;
      }

      .carousel-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
        margin: 72px 0 22px;
      }

      .carousel-header .section-title {
        margin: 0;
      }

      .carousel-controls {
        display: flex;
        gap: 10px;
      }

      .carousel-button {
        width: 42px;
        height: 42px;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: rgba(16, 20, 27, 0.72);
        color: var(--acid);
        cursor: pointer;
        transition:
          border-color 0.2s ease,
          transform 0.2s ease,
          background 0.2s ease;
      }

      .carousel-button:hover {
        border-color: var(--acid);
        background: rgba(216, 255, 62, 0.08);
        transform: translateY(-1px);
      }

      .carousel-track {
        display: flex;
        gap: 18px;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        scroll-behavior: smooth;
        padding: 2px 2px 16px;
        scrollbar-width: thin;
        scrollbar-color: rgba(216, 255, 62, 0.6) rgba(255, 255, 255, 0.08);
      }

      .gallery-item {
        flex: 0 0 min(320px, 82vw);
        aspect-ratio: 1 / 1;
        border: 1px solid var(--line);
        border-radius: 22px;
        overflow: hidden;
        background: rgba(16, 20, 27, 0.72);
        cursor: pointer;
        padding: 0;
        scroll-snap-align: start;
      }

      .gallery-item img {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition:
          transform 0.25s ease,
          opacity 0.25s ease;
      }

      .gallery-item:hover img {
        transform: scale(1.04);
        opacity: 0.88;
      }

      .archive-note {
        margin-top: 48px;
        border-left: 2px solid var(--acid);
        padding-left: 22px;
        color: var(--muted);
        font-size: 17px;
        line-height: 1.7;
        max-width: 820px;
      }

      footer {
        max-width: 1080px;
        margin: 80px auto 0;
        color: var(--muted);
        font-size: 12px;
        padding-top: 28px;
        border-top: 1px solid var(--line);
        display: flex;
        justify-content: space-between;
        gap: 20px;
      }

      .media-modal {
        position: fixed;
        inset: 0;
        z-index: 100;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 28px;
        background: rgba(0, 0, 0, 0.82);
        backdrop-filter: blur(10px);
      }

      .media-modal.is-open {
        display: flex;
      }

      .modal-content {
        position: relative;
        width: min(1100px, 96vw);
        max-height: 92vh;
        border: 1px solid var(--line);
        border-radius: 28px;
        background: rgba(7, 9, 12, 0.96);
        padding: 18px;
        box-shadow: 0 24px 90px rgba(0, 0, 0, 0.55);
      }

      .modal-image {
        display: block;
        width: 100%;
        max-height: 78vh;
        object-fit: contain;
        border-radius: 18px;
        background: #050608;
      }

      .modal-caption {
        margin: 14px 54px 0 4px;
        color: var(--muted);
        font-size: 13px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .modal-close {
        position: absolute;
        right: 18px;
        bottom: 14px;
        width: 42px;
        height: 42px;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: rgba(16, 20, 27, 0.9);
        color: var(--acid);
        cursor: pointer;
        font-size: 22px;
        line-height: 1;
      }

      .modal-close:hover {
        border-color: var(--acid);
      }

      @media (max-width: 900px) {
        .media-grid {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 860px) {
        .page {
          padding: 22px;
        }

        header {
          align-items: flex-start;
          flex-direction: column;
          padding-bottom: 44px;
        }

        nav {
          flex-wrap: wrap;
          gap: 14px 18px;
          font-size: 12px;
        }

        .hero-image {
          margin-top: 42px;
          border-radius: 20px;
        }

        .carousel-header {
          align-items: flex-start;
          flex-direction: column;
          gap: 14px;
        }

        .gallery-item {
          border-radius: 20px;
        }

        .media-modal {
          padding: 16px;
        }

        .modal-content {
          border-radius: 22px;
          padding: 12px;
        }

        .modal-image {
          border-radius: 14px;
        }

        footer {
          flex-direction: column;
        }
      }
    </style>
  </head>

  <body>
    <div class="page">
      <header>
        <a class="logo" href="/" aria-label="Itchy Lemon homepage">
          <img class="logo-icon" src="/favicon.png" alt="" />
          <span>Itchy Lemon</span>
        </a>

        <nav>
  <a href="/music">Music</a>
  <a href="/bio">Bio</a>
  <a href="/discography">Discography</a>
  <a class="active" href="/media">Media</a>
  <a href="/press-kit">Press Kit</a>
  <a href="/sets">Sets</a>
  <a href="/booking">Booking</a>
</nav>
      </header>

      <main>
        <p class="eyebrow">Gallery & Visual Archive</p>

        <h1>Media</h1>

        <p class="lead">
          Photos, flyers, visual archive and selected materials from the Itchy Lemon project.
        </p>

        <section class="hero-image" aria-label="Featured media archive banner">
          <button
            class="hero-trigger"
            type="button"
            data-full="/media-gallery-hero.jpg"
            data-title="Itchy Lemon Visual Archive"
            aria-label="Open Itchy Lemon visual archive banner"
          >
            <img src="/media-gallery-hero.jpg" alt="Itchy Lemon visual archive banner" />
          </button>
        </section>

        <h2 class="section-title">Archive Sections</h2>

        <section class="media-grid">
          <article class="media-card">
            <div>
              <p class="card-label">Photos</p>
              <h2>Artist & event images</h2>
              <p>
                Selected photos from events, artist sessions, press material and visual moments connected to the project.
              </p>
            </div>
          </article>

          <article class="media-card">
            <div>
              <p class="card-label">Flyers</p>
              <h2>Events & announcements</h2>
              <p>
                Flyers, posters and visual communication from past events, releases, collaborations and milestones.
              </p>
            </div>
          </article>

          <article class="media-card">
            <div>
              <p class="card-label">Press Assets</p>
              <h2>Press-ready material</h2>
              <p>
                Logos, banners, cover visuals and selected assets prepared for promoters, curators and collaborators.
              </p>
            </div>
          </article>
        </section>

        <section class="carousel" data-carousel>
          <div class="carousel-header">
            <h2 class="section-title">Photos</h2>
            <div class="carousel-controls">
              <button class="carousel-button" type="button" data-prev aria-label="Previous photos">‹</button>
              <button class="carousel-button" type="button" data-next aria-label="Next photos">›</button>
            </div>
          </div>

          <div class="carousel-track" data-track aria-label="Itchy Lemon photos">
            <button class="gallery-item" type="button" data-full="/media/photo-01.jpg" data-title="Photo 01">
              <img src="/media/photo-01.jpg" alt="Itchy Lemon photo 01" loading="lazy" />
            </button>
            <button class="gallery-item" type="button" data-full="/media/photo-02.jpg" data-title="Photo 02">
              <img src="/media/photo-02.jpg" alt="Itchy Lemon photo 02" loading="lazy" />
            </button>
            <button class="gallery-item" type="button" data-full="/media/photo-03.png" data-title="Photo 03">
              <img src="/media/photo-03.png" alt="Itchy Lemon photo 03" loading="lazy" />
            </button>
            <button class="gallery-item" type="button" data-full="/media/photo-04.png" data-title="Photo 04">
              <img src="/media/photo-04.png" alt="Itchy Lemon photo 04" loading="lazy" />
            </button>
            <button class="gallery-item" type="button" data-full="/media/photo-05.jpg" data-title="Photo 05">
              <img src="/media/photo-05.jpg" alt="Itchy Lemon photo 05" loading="lazy" />
            </button>
            <button class="gallery-item" type="button" data-full="/media/photo-08.jpg" data-title="Photo 08">
              <img src="/media/photo-08.jpg" alt="Itchy Lemon photo 08" loading="lazy" />
            </button>
          </div>
        </section>

        <section class="carousel" data-carousel>
          <div class="carousel-header">
            <h2 class="section-title">Flyers</h2>
            <div class="carousel-controls">
              <button class="carousel-button" type="button" data-prev aria-label="Previous flyers">‹</button>
              <button class="carousel-button" type="button" data-next aria-label="Next flyers">›</button>
            </div>
          </div>

          <div class="carousel-track" data-track aria-label="Itchy Lemon flyers">
            <button class="gallery-item" type="button" data-full="/media/flyer-01.png" data-title="Flyer 01">
              <img src="/media/flyer-01.png" alt="Itchy Lemon flyer 01" loading="lazy" />
            </button>
            <button class="gallery-item" type="button" data-full="/media/flyer-02.png" data-title="Flyer 02">
              <img src="/media/flyer-02.png" alt="Itchy Lemon flyer 02" loading="lazy" />
            </button>
            <button class="gallery-item" type="button" data-full="/media/flyer-03.png" data-title="Flyer 03">
              <img src="/media/flyer-03.png" alt="Itchy Lemon flyer 03" loading="lazy" />
            </button>
            <button class="gallery-item" type="button" data-full="/media/flyer-04.jpg" data-title="Flyer 04">
              <img src="/media/flyer-04.jpg" alt="Itchy Lemon flyer 04" loading="lazy" />
            </button>
            <button class="gallery-item" type="button" data-full="/media/flyer-05.png" data-title="Flyer 05">
              <img src="/media/flyer-05.png" alt="Itchy Lemon flyer 05" loading="lazy" />
            </button>
            <button class="gallery-item" type="button" data-full="/media/flyer-06.jpg" data-title="Flyer 06">
              <img src="/media/flyer-06.jpg" alt="Itchy Lemon flyer 06" loading="lazy" />
            </button>
            <button class="gallery-item" type="button" data-full="/media/flyer-07.png" data-title="Flyer 07">
              <img src="/media/flyer-07.png" alt="Itchy Lemon flyer 07" loading="lazy" />
            </button>
            <button class="gallery-item" type="button" data-full="/media/flyer-08.png" data-title="Flyer 08">
              <img src="/media/flyer-08.png" alt="Itchy Lemon flyer 08" loading="lazy" />
            </button>
            <button class="gallery-item" type="button" data-full="/media/flyer-09.jpg" data-title="Flyer 09">
              <img src="/media/flyer-09.jpg" alt="Itchy Lemon flyer 09" loading="lazy" />
            </button>
            <button class="gallery-item" type="button" data-full="/media/flyer-10.jpg" data-title="Flyer 10">
              <img src="/media/flyer-10.jpg" alt="Itchy Lemon flyer 10" loading="lazy" />
            </button>
            <button class="gallery-item" type="button" data-full="/media/flyer-11.jpg" data-title="Flyer 11">
              <img src="/media/flyer-11.jpg" alt="Itchy Lemon flyer 11" loading="lazy" />
            </button>
            <button class="gallery-item" type="button" data-full="/media/flyer-12.jpg" data-title="Flyer 12">
              <img src="/media/flyer-12.jpg" alt="Itchy Lemon flyer 12" loading="lazy" />
            </button>
          </div>
        </section>

        <section class="carousel" data-carousel>
          <div class="carousel-header">
            <h2 class="section-title">Press Assets</h2>
            <div class="carousel-controls">
              <button class="carousel-button" type="button" data-prev aria-label="Previous press assets">‹</button>
              <button class="carousel-button" type="button" data-next aria-label="Next press assets">›</button>
            </div>
          </div>

          <div class="carousel-track" data-track aria-label="Itchy Lemon press assets">
            <button class="gallery-item" type="button" data-full="/media/press-01.jpg" data-title="Press Asset 01">
              <img src="/media/press-01.jpg" alt="Itchy Lemon press asset 01" loading="lazy" />
            </button>
            <button class="gallery-item" type="button" data-full="/media/press-02.jpg" data-title="Press Asset 02">
              <img src="/media/press-02.jpg" alt="Itchy Lemon press asset 02" loading="lazy" />
            </button>
            <button class="gallery-item" type="button" data-full="/media/press-03.jpg" data-title="Press Asset 03">
              <img src="/media/press-03.jpg" alt="Itchy Lemon press asset 03" loading="lazy" />
            </button>
            <button class="gallery-item" type="button" data-full="/media/press-04.jpg" data-title="Press Asset 04">
              <img src="/media/press-04.jpg" alt="Itchy Lemon press asset 04" loading="lazy" />
            </button>
            <button class="gallery-item" type="button" data-full="/media/press-05.jpg" data-title="Press Asset 05">
              <img src="/media/press-05.jpg" alt="Itchy Lemon press asset 05" loading="lazy" />
            </button>
            <button class="gallery-item" type="button" data-full="/media/press-06.jpg" data-title="Press Asset 06">
              <img src="/media/press-06.jpg" alt="Itchy Lemon press asset 06" loading="lazy" />
            </button>
          </div>
        </section>

        <p class="archive-note">
          This page will be expanded with selected photos, flyers and downloadable visual assets from the Itchy Lemon archive.
        </p>
      </main>

      <footer>
        <span>© 2026 Itchy Lemon. All rights reserved.</span>
        <span>Photos · Flyers · Visual archive · Press assets</span>
      </footer>
    </div>

    <div class="media-modal" data-modal aria-hidden="true">
      <div class="modal-content" role="dialog" aria-modal="true" aria-label="Media preview">
        <img class="modal-image" data-modal-image src="" alt="" />
        <p class="modal-caption" data-modal-caption></p>
        <button class="modal-close" type="button" data-modal-close aria-label="Close preview">×</button>
      </div>
    </div>

    <script>
      const carousels = document.querySelectorAll("[data-carousel]");

      carousels.forEach((carousel) => {
        const track = carousel.querySelector("[data-track]");
        const prev = carousel.querySelector("[data-prev]");
        const next = carousel.querySelector("[data-next]");

        prev?.addEventListener("click", () => {
          track.scrollBy({
            left: -track.clientWidth * 0.85,
            behavior: "smooth",
          });
        });

        next?.addEventListener("click", () => {
          track.scrollBy({
            left: track.clientWidth * 0.85,
            behavior: "smooth",
          });
        });
      });

      const modal = document.querySelector("[data-modal]");
      const modalImage = document.querySelector("[data-modal-image]");
      const modalCaption = document.querySelector("[data-modal-caption]");
      const modalClose = document.querySelector("[data-modal-close]");
      const galleryItems = document.querySelectorAll("[data-full]");

      const openModal = (src, title) => {
        modalImage.src = src;
        modalImage.alt = title;
        modalCaption.textContent = title;
        modal.classList.add("is-open");
        modal.setAttribute("aria-hidden", "false");
        document.body.style.overflow = "hidden";
      };

      const closeModal = () => {
        modal.classList.remove("is-open");
        modal.setAttribute("aria-hidden", "true");
        modalImage.src = "";
        modalImage.alt = "";
        modalCaption.textContent = "";
        document.body.style.overflow = "";
      };

      galleryItems.forEach((item) => {
        item.addEventListener("click", () => {
          openModal(item.dataset.full, item.dataset.title);
        });
      });

      modalClose?.addEventListener("click", closeModal);

      modal?.addEventListener("click", (event) => {
        if (event.target === modal) {
          closeModal();
        }
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && modal.classList.contains("is-open")) {
          closeModal();
        }
      });
    </script>
  </body>
</html>