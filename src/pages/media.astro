<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Media gallery for Itchy Lemon — photos, flyers, visual archive and selected artist materials."
    />
    <meta name="author" content="Itchy Lemon" />
    <meta name="theme-color" content="#07090c" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Media | Itchy Lemon</title>

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href="https://itchy-lemon.pages.dev/media/" />

    <style>
      :root {
        --bg: #07090c;
        --bg-soft: #10141b;
        --text: #f4f4f0;
        --muted: #a7adb8;
        --acid: #d8ff3e;
        --line: rgba(255, 255, 255, 0.12);
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: Arial, Helvetica, sans-serif;
        background:
          radial-gradient(circle at top right, rgba(216, 255, 62, 0.12), transparent 34%),
          linear-gradient(135deg, #07090c 0%, #111827 48%, #050608 100%);
        color: var(--text);
        min-height: 100vh;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        max-width: 100%;
      }

      .page {
        min-height: 100vh;
        padding: 32px;
      }

      header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 24px;
        padding-bottom: 56px;
      }

      .logo {
        display: flex;
        align-items: center;
        gap: 10px;
        color: var(--acid);
        font-weight: 700;
        text-transform: uppercase;
        white-space: nowrap;
      }

      .logo-icon {
        display: block;
        width: 22px;
        height: 22px;
        object-fit: contain;
        flex-shrink: 0;
      }

      .logo span {
        display: inline-block;
        font-size: 14px;
        letter-spacing: 0.32em;
        line-height: 1;
      }

      nav {
        display: flex;
        gap: 22px;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--muted);
      }

      nav a {
        transition: color 0.2s ease;
      }

      nav a:hover,
      nav a.active {
        color: var(--acid);
      }

      main {
        max-width: 1080px;
        margin: 0 auto;
      }

      .eyebrow {
        color: var(--acid);
        text-transform: uppercase;
        letter-spacing: 0.24em;
        font-size: 13px;
        margin: 0 0 18px;
      }

      h1 {
        margin: 0;
        font-size: clamp(48px, 8vw, 104px);
        line-height: 0.9;
        letter-spacing: -0.06em;
        text-transform: uppercase;
      }

      .lead {
        margin: 32px 0 0;
        max-width: 840px;
        font-size: clamp(22px, 3vw, 34px);
        line-height: 1.16;
        color: var(--text);
      }

      .hero-image {
        margin-top: 56px;
        border: 1px solid var(--line);
        border-radius: 28px;
        overflow: hidden;
        background:
          linear-gradient(135deg, rgba(216, 255, 62, 0.08), transparent),
          rgba(16, 20, 27, 0.72);
        box-shadow: 0 24px 80px rgba(0, 0, 0, 0.32);
      }

      .hero-image img {
        display: block;
        width: 100%;
        height: auto;
      }

      .section-title {
        margin: 72px 0 22px;
        color: var(--acid);
        font-size: 13px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }

      .media-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 22px;
      }

      .media-card {
        border: 1px solid var(--line);
        background: rgba(16, 20, 27, 0.72);
        border-radius: 28px;
        padding: 24px;
        min-height: 220px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        backdrop-filter: blur(12px);
      }

      .media-card h2 {
        margin: 0;
        font-size: 28px;
        line-height: 1;
        letter-spacing: -0.04em;
      }

      .media-card p {
        margin: 18px 0 0;
        color: var(--muted);
        font-size: 15px;
        line-height: 1.6;
      }

      .card-label {
        color: var(--acid);
        text-transform: uppercase;
        letter-spacing: 0.18em;
        font-size: 12px;
        margin: 0 0 18px;
      }

      .archive-note {
        margin-top: 48px;
        border-left: 2px solid var(--acid);
        padding-left: 22px;
        color: var(--muted);
        font-size: 17px;
        line-height: 1.7;
        max-width: 820px;
      }

      footer {
        max-width: 1080px;
        margin: 80px auto 0;
        color: var(--muted);
        font-size: 12px;
        padding-top: 28px;
        border-top: 1px solid var(--line);
        display: flex;
        justify-content: space-between;
        gap: 20px;
      }

      @media (max-width: 900px) {
        .media-grid {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 860px) {
        .page {
          padding: 22px;
        }

        header {
          align-items: flex-start;
          flex-direction: column;
          padding-bottom: 44px;
        }

        nav {
          flex-wrap: wrap;
          gap: 14px 18px;
          font-size: 12px;
        }

        .hero-image {
          margin-top: 42px;
          border-radius: 20px;
        }

        footer {
          flex-direction: column;
        }
      }
    </style>
  </head>

  <body>
    <div class="page">
      <header>
        <a class="logo" href="/" aria-label="Itchy Lemon homepage">
          <img class="logo-icon" src="/favicon.png" alt="" />
          <span>Itchy Lemon</span>
        </a>

        <nav aria-label="Main navigation">
          <a href="/music">Music</a>
          <a href="/bio">Bio</a>
          <a href="/discography">Discography</a>
          <a class="active" href="/media">Media</a>
          <a href="/press-kit">Press Kit</a>
          <a href="/booking">Booking</a>
        </nav>
      </header>

      <main>
        <p class="eyebrow">Gallery & Visual Archive</p>

        <h1>Media</h1>

        <p class="lead">
          Photos, flyers, visual archive and selected materials from the Itchy Lemon project.
        </p>

        <section class="hero-image" aria-label="Featured media archive banner">
          <img src="/media-gallery-hero.jpg" alt="Itchy Lemon visual archive banner" />
        </section>

        <h2 class="section-title">Archive Sections</h2>

        <section class="media-grid">
          <article class="media-card">
            <div>
              <p class="card-label">Photos</p>
              <h2>Artist & event images</h2>
              <p>
                Selected photos from events, artist sessions, press material and visual moments connected to the project.
              </p>
            </div>
          </article>

          <article class="media-card">
            <div>
              <p class="card-label">Flyers</p>
              <h2>Events & announcements</h2>
              <p>
                Flyers, posters and visual communication from past events, releases, collaborations and milestones.
              </p>
            </div>
          </article>

          <article class="media-card">
            <div>
              <p class="card-label">Visual Assets</p>
              <h2>Press-ready material</h2>
              <p>
                Logos, banners, cover visuals and selected assets prepared for promoters, curators and collaborators.
              </p>
            </div>
          </article>
        </section>

        <p class="archive-note">
          This page will be expanded with selected photos, flyers and downloadable visual assets from the Itchy Lemon archive.
        </p>
      </main>

      <footer>
        <span>© 2026 Itchy Lemon. All rights reserved.</span>
        <span>Photos · Flyers · Visual archive · Press assets</span>
      </footer>
    </div>
  </body>
</html>