    type: "Radio Show",
    url: "https://www.mixcloud.com/ITCHY_LEMON_DjProducer/itchy-lemon-fresh-beats-39-rec-live-at-dj-live-tv-griffons-club-nov-2015/",
  },
  {
    number: "#38",
    year: "2015",
    title: "Fresh Beats Radio Show #38",
    meta: "October 2015",
    type: "Radio Show",
    url: "https://www.mixcloud.com/ITCHY_LEMON_DjProducer/itchy-lemon-fresh-beats-38-oct-2015/",
  },
  {
    number: "#37",
    year: "2015",
    title: "Fresh Beats Radio Show #37",
    meta: "September 2015",
    type: "Radio Show",
    url: "https://www.mixcloud.com/ITCHY_LEMON_DjProducer/itchy-lemon-fresh-beats-37-sep-2015/",
  },
  {
    number: "#36",
    year: "2015",
    title: "Fresh Beats Radio Show #36",
    meta: "August 2015",
    type: "Radio Show",
    url: "https://www.mixcloud.com/ITCHY_LEMON_DjProducer/itchy-lemon-fresh-beats-36-ago-2015/",
  },
];

const videoSets = [
  {
    title: "DJ LIVE TV - Itchy Lemon - Session #21",
    embedUrl: "https://www.youtube.com/embed/rnIKZc25WNk",
  },
  {
    title: "Itchy Lemon Live DJ Set 02",
    embedUrl: "https://www.youtube.com/embed/zFDTLWB483Q",
  },
  {
    title: "Itchy Lemon Live DJ Set 03",
    embedUrl: "https://www.youtube.com/embed/QvmN2MWRmxk",
  },
  {
    title: "Itchy Lemon Live DJ Set 04",
    embedUrl: "https://www.youtube.com/embed/6iyZGzSfsBI",
  },
  {
    title: "Itchy Lemon Live DJ Set 05",
    embedUrl: "https://www.youtube.com/embed/77RmqNOxkDw",
  },
  {
    title: "Itchy Lemon Live DJ Set 06",
    embedUrl: "https://www.youtube.com/embed/8-kOMD1khsM",
  },
];

const audioSets = [
  {
    label: "Audio",
    title: "Live DJ Sets",
    meta: "Selected audio recordings hosted directly on the website will be added here.",
    type: "Audio",
    status: "Coming soon",
  },
];

const mixcloudUrl = "https://www.mixcloud.com/ITCHY_LEMON_DjProducer/";

const getCloudcastKey = (url) => {
  const parsedUrl = new URL(url);
  return parsedUrl.pathname;
};

const enhancedRadioShows = radioShows.map((set) => ({
  ...set,
  key: getCloudcastKey(set.url),
}));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Radio shows, DJ sets and live recordings by Itchy Lemon — House, Deep House, Tech House and Melodic Techno."
    />
    <meta name="author" content="Itchy Lemon" />
    <meta name="theme-color" content="#07090c" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Sets | Itchy Lemon</title>

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href="https://itchy-lemon.pages.dev/sets/" />

    <style>
      :root {
        --bg: #07090c;
        --bg-soft: #10141b;
        --text: #f4f4f0;
        --muted: #a7adb8;
        --acid: #d8ff3e;
        --line: rgba(255, 255, 255, 0.12);
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: Arial, Helvetica, sans-serif;
        background:
          radial-gradient(circle at top right, rgba(216, 255, 62, 0.12), transparent 34%),
          linear-gradient(135deg, #07090c 0%, #111827 48%, #050608 100%);
        color: var(--text);
        min-height: 100vh;
      }

      body.modal-open {
        overflow: hidden;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      button {
        font: inherit;
      }

      .page {
        min-height: 100vh;
        padding: 32px;
        transition: padding-bottom 0.2s ease;
      }

      header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 24px;
        padding-bottom: 56px;
      }

      .logo {
        display: flex;
        align-items: center;
        gap: 10px;
        color: var(--acid);
        font-weight: 700;
        text-transform: uppercase;
        white-space: nowrap;
      }

      .logo-icon {
        display: block;
        width: 22px;
        height: 22px;
        object-fit: contain;
        flex-shrink: 0;
      }

      .logo span {
        display: inline-block;
        font-size: 14px;
        letter-spacing: 0.32em;
        line-height: 1;
      }

      nav {
        display: flex;
        gap: 22px;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--muted);
      }

      nav a {
        transition: color 0.2s ease;
      }

      nav a:hover,
      nav a.active {
        color: var(--acid);
      }

      main {
        max-width: 1080px;
        margin: 0 auto;
      }

      .eyebrow {
        color: var(--acid);
        text-transform: uppercase;
        letter-spacing: 0.24em;
        font-size: 13px;
        margin: 0 0 18px;
      }

      h1 {
        margin: 0;
        font-size: clamp(48px, 8vw, 104px);
        line-height: 0.9;
        letter-spacing: -0.06em;
        text-transform: uppercase;
      }

      .lead {
        margin: 32px 0 0;
        max-width: 780px;
        font-size: clamp(22px, 3vw, 34px);
        line-height: 1.16;
        color: var(--text);
      }

      .sets-intro {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 28px;
        align-items: end;
        margin-top: 42px;
      }

      .profile-card {
        border: 1px solid var(--line);
        border-radius: 28px;
        background: rgba(16, 20, 27, 0.72);
        padding: 24px;
        min-width: 260px;
        backdrop-filter: blur(12px);
      }

      .profile-card p {
        margin: 0;
        color: var(--muted);
        font-size: 14px;
        line-height: 1.6;
      }

      .profile-card strong {
        display: block;
        color: var(--acid);
        text-transform: uppercase;
        letter-spacing: 0.16em;
        font-size: 12px;
        margin-bottom: 10px;
      }

      .section-title {
        margin: 72px 0 22px;
        color: var(--acid);
        font-size: 13px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }

      .sets-list {
        display: grid;
        gap: 0;
      }

      .set-row {
        width: 100%;
        display: grid;
        grid-template-columns: 80px 1fr 120px 110px;
        gap: 22px;
        align-items: start;
        border: 0;
        border-top: 1px solid var(--line);
        padding: 24px 0;
        background: transparent;
        color: var(--text);
        cursor: pointer;
        text-align: left;
      }

      .set-row:hover .set-title,
      .set-row.is-active .set-title {
        color: var(--acid);
      }

      .set-row:hover .listen,
      .set-row.is-active .listen {
        color: #050608;
        background: var(--acid);
        border-color: var(--acid);
        transform: translateY(-2px);
      }

      .set-row.is-disabled {
        cursor: default;
        opacity: 0.68;
      }

      .set-row.is-disabled:hover .set-title {
        color: var(--text);
      }

      .set-row.is-disabled:hover .listen {
        color: var(--muted);
        background: transparent;
        border-color: var(--line);
        transform: none;
      }

      .set-episode {
        color: var(--acid);
        font-size: 14px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }

      .set-title {
        margin: 0;
        color: var(--text);
        font-size: 26px;
        line-height: 1.05;
        letter-spacing: -0.04em;
        transition: color 0.2s ease;
      }

      .set-meta {
        margin: 9px 0 0;
        color: var(--muted);
        font-size: 15px;
        line-height: 1.55;
      }

      .set-type {
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.14em;
        font-size: 12px;
        line-height: 1.45;
        text-align: right;
      }

      .listen {
        justify-self: end;
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 9px 13px;
        color: var(--muted);
        font-size: 11px;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        white-space: nowrap;
        transition: 0.2s ease;
      }

      .mixcloud-text-cta {
        margin-top: 34px;
        padding-top: 28px;
        border-top: 1px solid var(--line);
      }

      .mixcloud-text-cta p {
        margin: 0;
        max-width: 760px;
        color: var(--muted);
        font-size: 17px;
        line-height: 1.7;
      }

      .mixcloud-text-cta a {
        color: var(--acid);
        font-weight: 700;
        text-decoration: none;
        border-bottom: 1px solid rgba(216, 255, 62, 0.45);
        transition:
          color 0.2s ease,
          border-color 0.2s ease;
      }

      .mixcloud-text-cta a:hover {
        color: var(--text);
        border-color: var(--text);
      }

      .video-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 32px 30px;
        border-top: 1px solid var(--line);
        padding-top: 30px;
      }

      .video-card {
        overflow: hidden;
        border: 1px solid var(--line);
        border-radius: 22px;
        background: rgba(16, 20, 27, 0.72);
        backdrop-filter: blur(12px);
        box-shadow: 0 24px 80px rgba(0, 0, 0, 0.24);
        transition:
          border-color 0.25s ease,
          transform 0.25s ease,
          background 0.25s ease;
      }

      .video-card:hover {
        border-color: rgba(216, 255, 62, 0.45);
        background: rgba(16, 20, 27, 0.86);
        transform: translateY(-3px);
      }

      .video-preview-button {
        position: relative;
        display: block;
        width: 100%;
        aspect-ratio: 16 / 9;
        border: 0;
        padding: 0;
        overflow: hidden;
        background: #050608;
        cursor: pointer;
      }

      .video-preview-button iframe {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        border: 0;
        pointer-events: none;
      }

      .video-preview-button::after {
        content: "";
        position: absolute;
        inset: 0;
        z-index: 1;
        background:
          linear-gradient(180deg, rgba(5, 6, 8, 0.02), rgba(5, 6, 8, 0.28)),
          radial-gradient(circle at center, rgba(216, 255, 62, 0.08), transparent 42%);
        pointer-events: none;
      }

      .video-play-icon {
        position: absolute;
        left: 50%;
        top: 50%;
        z-index: 2;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 52px;
        height: 52px;
        border: 1px solid rgba(216, 255, 62, 0.72);
        border-radius: 999px;
        background: rgba(5, 6, 8, 0.72);
        color: var(--acid);
        font-size: 27px;
        line-height: 1;
        transform: translate(-50%, -50%);
        transition:
          transform 0.25s ease,
          background 0.25s ease,
          color 0.25s ease;
      }

      .video-card:hover .video-play-icon {
        background: var(--acid);
        color: #050608;
        transform: translate(-50%, -50%) scale(1.06);
      }

      .video-modal {
        position: fixed;
        inset: 0;
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 72px 36px;
        background: rgba(5, 6, 8, 0.92);
        backdrop-filter: blur(18px);
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.22s ease;
      }

      .video-modal.is-open {
        opacity: 1;
        pointer-events: auto;
      }

      .video-modal-panel {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        width: min(86vw, 1180px);
        max-width: calc((100vh - 144px) * 16 / 9);
        background: transparent;
        transform: translateY(14px) scale(0.98);
        transition: transform 0.22s ease;
      }

      .video-modal.is-open .video-modal-panel {
        transform: translateY(0) scale(1);
      }

      .video-modal-frame {
        position: relative;
        width: 100%;
        aspect-ratio: 16 / 9;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.14);
        border-radius: 28px;
        background: #000;
        box-shadow: 0 32px 120px rgba(0, 0, 0, 0.65);
      }

      .video-modal-frame iframe {
        display: block;
        width: 100%;
        height: 100%;
        border: 0;
      }

      .video-modal-close {
        position: absolute;
        top: -18px;
        right: -18px;
        z-index: 3;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 46px;
        height: 46px;
        border: 1px solid rgba(255, 255, 255, 0.24);
        border-radius: 999px;
        background: rgba(5, 6, 8, 0.88);
        color: var(--text);
        font-size: 26px;
        line-height: 1;
        cursor: pointer;
        transition:
          color 0.2s ease,
          border-color 0.2s ease,
          background 0.2s ease,
          transform 0.2s ease;
      }

      .video-modal-close:hover {
        color: #050608;
        border-color: var(--acid);
        background: var(--acid);
        transform: rotate(90deg);
      }

      .booking-cta {
        margin-top: 64px;
        border: 1px solid var(--line);
        border-radius: 28px;
        background:
          linear-gradient(135deg, rgba(216, 255, 62, 0.1), transparent),
          rgba(16, 20, 27, 0.72);
        padding: 32px;
        backdrop-filter: blur(12px);
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 28px;
        align-items: center;
      }

      .booking-cta p {
        margin: 0 0 14px;
        color: var(--acid);
        text-transform: uppercase;
        letter-spacing: 0.18em;
        font-size: 12px;
      }

      .booking-cta h2 {
        margin: 0;
        font-size: clamp(32px, 5vw, 56px);
        line-height: 0.95;
        letter-spacing: -0.06em;
        text-transform: uppercase;
      }

      .booking-cta .cta-copy {
        margin-top: 18px;
        max-width: 680px;
        color: var(--muted);
        font-size: 17px;
        line-height: 1.7;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 48px;
        padding: 0 22px;
        border-radius: 999px;
        border: 1px solid var(--acid);
        background: var(--acid);
        color: #050608;
        font-size: 13px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        white-space: nowrap;
        transition:
          transform 0.2s ease,
          background 0.2s ease,
          border-color 0.2s ease;
      }

      .button:hover {
        transform: translateY(-2px);
      }

      footer {
        max-width: 1080px;
        margin: 80px auto 0;
        color: var(--muted);
        font-size: 12px;
        padding-top: 28px;
        border-top: 1px solid var(--line);
        display: flex;
        justify-content: space-between;
        gap: 20px;
      }

      footer a {
        color: var(--muted);
      }

      footer a:hover {
        color: var(--acid);
      }

      @media (max-width: 980px) {
        .set-row {
          grid-template-columns: 1fr;
          gap: 10px;
        }

        .set-type {
          text-align: left;
        }

        .listen {
          justify-self: start;
          margin-top: 4px;
        }

        .video-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
          gap: 28px;
        }
      }

      @media (max-width: 900px) {
        .sets-intro,
        .booking-cta {
          grid-template-columns: 1fr;
        }

        .profile-card {
          min-width: 0;
        }
      }

      @media (max-width: 860px) {
        .page {
          padding: 22px;
        }

        header {
          align-items: flex-start;
          flex-direction: column;
        }

        nav {
          flex-wrap: wrap;
        }

        .section-title {
          margin-top: 56px;
        }

        .mixcloud-text-cta {
          margin-top: 28px;
          padding-top: 24px;
        }

        .mixcloud-text-cta p {
          font-size: 16px;
        }

        .video-grid {
          grid-template-columns: 1fr;
          gap: 24px;
        }

        .video-card {
          border-radius: 20px;
        }

        .video-play-icon {
          width: 48px;
          height: 48px;
          font-size: 25px;
        }

        .video-modal {
          padding: 44px 16px;
        }

        .video-modal-panel {
          width: 100%;
          max-width: calc((100vh - 88px) * 16 / 9);
        }

        .video-modal-frame {
          border-radius: 20px;
        }

        .video-modal-close {
          top: -12px;
          right: -8px;
          width: 42px;
          height: 42px;
          font-size: 24px;
        }

        .booking-cta {
          border-radius: 24px;
          padding: 18px;
        }

        .button {
          width: 100%;
        }

        footer {
          flex-direction: column;
        }
      }
    </style>
  </head>

  <body>
    <div class="page">
      <header>
        <a class="logo" href="/" aria-label="Itchy Lemon homepage">
          <img class="logo-icon" src="/favicon.png" alt="" />
          <span>Itchy Lemon</span>
        </a>

        <nav aria-label="Main navigation">
          <a href="/music">Music</a>
          <a href="/bio">Bio</a>
          <a href="/discography">Discography</a>
          <a href="/media">Media</a>
          <a href="/press-kit">Press Kit</a>
          <a class="active" href="/sets">Sets</a>
          <a href="/booking">Booking</a>
        </nav>
      </header>

      <main>
        <p class="eyebrow">Radio Shows & DJ Sets</p>

        <h1>Sets</h1>

        <div class="sets-intro">
          <p class="lead">
            Selected radio shows, live DJ sets and recordings from the Itchy Lemon archive.
          </p>

          <aside class="profile-card">
            <strong>Mixcloud Archive</strong>
            <p>
              House, Deep House, Tech House and melodic electronic journeys — curated for listening without leaving the site.
            </p>
          </aside>
        </div>

        <h2 class="section-title">Fresh Beats Radio Show</h2>

        <section class="sets-list" aria-label="Itchy Lemon radio shows">
          {enhancedRadioShows.map((set, index) => (
            <button
              class={`set-row ${index === 0 ? "is-active" : ""}`}
              type="button"
              data-set-card
              data-set-index={index}
            >
              <div class="set-episode">{set.number}</div>

              <div>
                <h2 class="set-title">{set.title}</h2>
                <p class="set-meta">{set.meta}</p>
              </div>

              <div class="set-type">{set.type}</div>

              <span class="listen" aria-label={`Play ${set.title}`}>
                Play
              </span>
            </button>
          ))}
        </section>

        <section class="mixcloud-text-cta" aria-label="Listen to more Itchy Lemon sets on Mixcloud">
          <p>
            Want to hear more Itchy Lemon radio shows and DJ sets?
            <a href={mixcloudUrl} target="_blank" rel="noreferrer">
              Explore the full Mixcloud archive
            </a>.
          </p>
        </section>

        <h2 class="section-title">Live DJ Sets · Video</h2>

        <section class="video-grid" aria-label="Itchy Lemon live DJ sets from YouTube">
          {videoSets.map((set) => (
            <article class="video-card">
              <button
                class="video-preview-button"
                type="button"
                data-video-trigger
                data-video-title={set.title}
                data-video-url={set.embedUrl}
                aria-label={`Play ${set.title}`}
              >
                <iframe
                  src={`${set.embedUrl}?controls=0&modestbranding=1&rel=0`}
                  title={`${set.title} preview`}
                  loading="lazy"
                  allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                ></iframe>

                <span class="video-play-icon" aria-hidden="true">›</span>
              </button>
            </article>
          ))}
        </section>

        <h2 class="section-title">Live DJ Sets · Audio</h2>

        <section class="sets-list" aria-label="Itchy Lemon live DJ sets from audio files">
          {audioSets.map((set) => (
            <article class="set-row is-disabled">
              <div class="set-episode">{set.label}</div>

              <div>
                <h2 class="set-title">{set.title}</h2>
                <p class="set-meta">{set.meta}</p>
              </div>

              <div class="set-type">{set.type}</div>

              <span class="listen">
                {set.status}
              </span>
            </article>
          ))}
        </section>

        <section class="booking-cta" aria-label="Book Itchy Lemon">
          <div>
            <p>Like the sound?</p>
            <h2>Book Itchy Lemon</h2>
            <div class="cta-copy">
              Available for club DJ sets, guest mixes, electronic music events and selected collaborations.
            </div>
          </div>

          <a class="button" href="/booking">
            Request Booking
          </a>
        </section>
      </main>

      <footer>
        <span>© 2026 Itchy Lemon. All rights reserved.</span>
        <span>
          Radio shows · DJ sets · YouTube videos · Audio recordings ·
          <a href="/privacy-policy">Privacy Policy</a>
        </span>
      </footer>
    </div>

    <div class="video-modal" data-video-modal aria-hidden="true">
      <div class="video-modal-panel" role="dialog" aria-modal="true" aria-label="Live DJ Set video player">
        <button
          class="video-modal-close"
          type="button"
          data-video-close
          aria-label="Close video"
        >
          ×
        </button>

        <div class="video-modal-frame">
          <iframe
            data-video-player
            src=""
            title="Live DJ Set video player"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </div>

    <GlobalMixcloudPlayer />
    <HubSpotTracking />

    <script>
      const setCards = document.querySelectorAll("[data-set-card]");

      const updateActiveCard = (index) => {
        setCards.forEach((card) => {
          card.classList.remove("is-active");
        });

        const activeCard = document.querySelector(`[data-set-index="${index}"]`);

        if (activeCard) {
          activeCard.classList.add("is-active");
        }
      };

      const storedIndex = Number(localStorage.getItem("itchyLemonPlayerIndex") || "0");
      updateActiveCard(storedIndex);

      setCards.forEach((card) => {
        card.addEventListener("click", () => {
          const index = Number(card.dataset.setIndex || "0");

          updateActiveCard(index);

          document.dispatchEvent(
            new CustomEvent("itchy-lemon-load-set", {
              detail: { index },
            })
          );
        });
      });

      document.addEventListener("itchy-lemon-player-active-set", (event) => {
        const index = Number(event.detail?.index || "0");
        updateActiveCard(index);
      });

      const videoModal = document.querySelector("[data-video-modal]");
      const videoPlayer = document.querySelector("[data-video-player]");
      const videoTriggers = document.querySelectorAll("[data-video-trigger]");
      const videoClose = document.querySelector("[data-video-close]");

      const openVideoModal = (title, url) => {
        if (!videoModal || !videoPlayer) return;

        videoPlayer.setAttribute("title", title);
        videoPlayer.setAttribute("src", `${url}?autoplay=1&rel=0`);

        videoModal.classList.add("is-open");
        videoModal.setAttribute("aria-hidden", "false");
        document.body.classList.add("modal-open");
      };

      const closeVideoModal = () => {
        if (!videoModal || !videoPlayer) return;

        videoModal.classList.remove("is-open");
        videoModal.setAttribute("aria-hidden", "true");
        document.body.classList.remove("modal-open");

        videoPlayer.setAttribute("src", "");
      };

      videoTriggers.forEach((trigger) => {
        trigger.addEventListener("click", () => {
          const title = trigger.dataset.videoTitle || "Live DJ Set";
          const url = trigger.dataset.videoUrl;

          if (url) {
            openVideoModal(title, url);
          }
        });
      });

      if (videoClose) {
        videoClose.addEventListener("click", closeVideoModal);
      }

      if (videoModal) {
        videoModal.addEventListener("click", (event) => {
          if (event.target === videoModal) {
            closeVideoModal();
          }
        });
      }

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          closeVideoModal();
        }
      });
    </script>
  </body>
</html>