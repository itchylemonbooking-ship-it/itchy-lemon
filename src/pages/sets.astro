---
const sets = [
  {
    title: "ITCHY LEMON Fresh Beats #41",
    url: "https://www.mixcloud.com/ITCHY_LEMON_DjProducer/itchy-lemon-fresh-beats-41-jan-2016/",
  },
  {
    title: "ITCHY LEMON Fresh Beats #40",
    url: "https://www.mixcloud.com/ITCHY_LEMON_DjProducer/itchy-lemon-fresh-beats-40-rec-live-at-orange-room-porto-studio-series-episode-108-dec-2015/",
  },
  {
    title: "ITCHY LEMON Fresh Beats #39",
    url: "https://www.mixcloud.com/ITCHY_LEMON_DjProducer/itchy-lemon-fresh-beats-39-rec-live-at-dj-live-tv-griffons-club-nov-2015/",
  },
  {
    title: "ITCHY LEMON Fresh Beats #38",
    url: "https://www.mixcloud.com/ITCHY_LEMON_DjProducer/itchy-lemon-fresh-beats-38-oct-2015/",
  },
  {
    title: "ITCHY LEMON Fresh Beats #37",
    url: "https://www.mixcloud.com/ITCHY_LEMON_DjProducer/itchy-lemon-fresh-beats-37-sep-2015/",
  },
  {
    title: "ITCHY LEMON Fresh Beats #36",
    url: "https://www.mixcloud.com/ITCHY_LEMON_DjProducer/itchy-lemon-fresh-beats-36-ago-2015/",
  },
];

const getEmbedUrl = (url) =>
  `https://www.mixcloud.com/widget/iframe/?hide_cover=1&light=0&feed=${encodeURIComponent(url)}`;

const getCloudcastKey = (url) => {
  const parsedUrl = new URL(url);
  return parsedUrl.pathname;
};

const enhancedSets = sets.map((set) => ({
  ...set,
  key: getCloudcastKey(set.url),
}));

const featuredSet = enhancedSets[0];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="DJ sets, radio shows and live recordings by Itchy Lemon — House, Deep House, Tech House and Melodic Techno."
    />
    <meta name="author" content="Itchy Lemon" />
    <meta name="theme-color" content="#07090c" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Sets | Itchy Lemon</title>

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href="https://itchy-lemon.pages.dev/sets/" />

    <style>
      :root {
        --bg: #07090c;
        --bg-soft: #10141b;
        --text: #f4f4f0;
        --muted: #a7adb8;
        --acid: #d8ff3e;
        --line: rgba(255, 255, 255, 0.12);
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: Arial, Helvetica, sans-serif;
        background:
          radial-gradient(circle at top right, rgba(216, 255, 62, 0.12), transparent 34%),
          linear-gradient(135deg, #07090c 0%, #111827 48%, #050608 100%);
        color: var(--text);
        min-height: 100vh;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      button {
        font: inherit;
      }

      .page {
        min-height: 100vh;
        padding: 32px 32px 150px;
      }

      header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 24px;
        padding-bottom: 56px;
      }

      .logo {
        display: flex;
        align-items: center;
        gap: 10px;
        color: var(--acid);
        font-weight: 700;
        text-transform: uppercase;
        white-space: nowrap;
      }

      .logo-icon {
        display: block;
        width: 22px;
        height: 22px;
        object-fit: contain;
        flex-shrink: 0;
      }

      .logo span {
        display: inline-block;
        font-size: 14px;
        letter-spacing: 0.32em;
        line-height: 1;
      }

      nav {
        display: flex;
        gap: 22px;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--muted);
      }

      nav a {
        transition: color 0.2s ease;
      }

      nav a:hover,
      nav a.active {
        color: var(--acid);
      }

      main {
        max-width: 1080px;
        margin: 0 auto;
      }

      .eyebrow {
        color: var(--acid);
        text-transform: uppercase;
        letter-spacing: 0.24em;
        font-size: 13px;
        margin: 0 0 18px;
      }

      h1 {
        margin: 0;
        font-size: clamp(48px, 8vw, 104px);
        line-height: 0.9;
        letter-spacing: -0.06em;
        text-transform: uppercase;
      }

      .lead {
        margin: 32px 0 0;
        max-width: 840px;
        font-size: clamp(22px, 3vw, 34px);
        line-height: 1.16;
        color: var(--text);
      }

      .sets-intro {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 28px;
        align-items: end;
        margin-top: 42px;
      }

      .profile-card {
        border: 1px solid var(--line);
        border-radius: 28px;
        background: rgba(16, 20, 27, 0.72);
        padding: 24px;
        min-width: 260px;
        backdrop-filter: blur(12px);
      }

      .profile-card p {
        margin: 0;
        color: var(--muted);
        font-size: 14px;
        line-height: 1.6;
      }

      .profile-card strong {
        display: block;
        color: var(--acid);
        text-transform: uppercase;
        letter-spacing: 0.16em;
        font-size: 12px;
        margin-bottom: 10px;
      }

      .sets-list {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 18px;
        margin-top: 64px;
      }

      .set-card {
        width: 100%;
        min-height: 150px;
        border: 1px solid var(--line);
        border-radius: 26px;
        background: rgba(16, 20, 27, 0.72);
        color: var(--text);
        padding: 24px;
        backdrop-filter: blur(12px);
        cursor: pointer;
        text-align: left;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        gap: 24px;
        transition:
          transform 0.2s ease,
          border-color 0.2s ease,
          background 0.2s ease;
      }

      .set-card:hover,
      .set-card.is-active {
        transform: translateY(-2px);
        border-color: rgba(216, 255, 62, 0.42);
        background:
          linear-gradient(135deg, rgba(216, 255, 62, 0.08), transparent),
          rgba(16, 20, 27, 0.86);
      }

      .set-card strong {
        display: block;
        color: var(--text);
        font-size: clamp(20px, 2.5vw, 28px);
        line-height: 1.08;
        letter-spacing: -0.05em;
      }

      .set-card span {
        display: block;
        color: var(--muted);
        font-size: 14px;
        line-height: 1.55;
      }

      .set-card-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        padding-top: 18px;
        border-top: 1px solid var(--line);
      }

      .set-card-footer span {
        color: var(--acid);
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.14em;
      }

      .booking-cta {
        margin-top: 64px;
        border: 1px solid var(--line);
        border-radius: 28px;
        background:
          linear-gradient(135deg, rgba(216, 255, 62, 0.1), transparent),
          rgba(16, 20, 27, 0.72);
        padding: 32px;
        backdrop-filter: blur(12px);
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 28px;
        align-items: center;
      }

      .booking-cta p {
        margin: 0 0 14px;
        color: var(--acid);
        text-transform: uppercase;
        letter-spacing: 0.18em;
        font-size: 12px;
      }

      .booking-cta h2 {
        margin: 0;
        font-size: clamp(32px, 5vw, 56px);
        line-height: 0.95;
        letter-spacing: -0.06em;
        text-transform: uppercase;
      }

      .booking-cta .cta-copy {
        margin-top: 18px;
        max-width: 680px;
        color: var(--muted);
        font-size: 17px;
        line-height: 1.7;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 48px;
        padding: 0 22px;
        border-radius: 999px;
        border: 1px solid var(--acid);
        background: var(--acid);
        color: #050608;
        font-size: 13px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        white-space: nowrap;
        transition:
          transform 0.2s ease,
          background 0.2s ease,
          border-color 0.2s ease;
      }

      .button:hover {
        transform: translateY(-2px);
      }

      footer {
        max-width: 1080px;
        margin: 80px auto 0;
        color: var(--muted);
        font-size: 12px;
        padding-top: 28px;
        border-top: 1px solid var(--line);
        display: flex;
        justify-content: space-between;
        gap: 20px;
      }

      footer a {
        color: var(--muted);
      }

      footer a:hover {
        color: var(--acid);
      }

      .footer-player {
        position: fixed;
        left: 50%;
        bottom: 14px;
        z-index: 100;
        width: min(1180px, calc(100% - 28px));
        transform: translateX(-50%);
        border: 1px solid rgba(216, 255, 62, 0.22);
        border-radius: 22px;
        background:
          linear-gradient(135deg, rgba(216, 255, 62, 0.07), transparent),
          rgba(7, 9, 12, 0.96);
        box-shadow: 0 18px 70px rgba(0, 0, 0, 0.55);
        backdrop-filter: blur(18px);
        padding: 12px;
      }

      .footer-player-inner {
        display: grid;
        grid-template-columns: 42px minmax(160px, 240px) 1fr 42px;
        gap: 12px;
        align-items: center;
      }

      .player-control {
        width: 42px;
        height: 42px;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: rgba(216, 255, 62, 0.06);
        color: var(--acid);
        cursor: pointer;
        font-size: 18px;
        line-height: 1;
        transition:
          transform 0.2s ease,
          border-color 0.2s ease,
          background 0.2s ease;
      }

      .player-control:hover {
        transform: translateY(-2px);
        border-color: var(--acid);
        background: rgba(216, 255, 62, 0.12);
      }

      .footer-player-info {
        min-width: 0;
      }

      .footer-player-label {
        display: block;
        color: var(--acid);
        text-transform: uppercase;
        letter-spacing: 0.16em;
        font-size: 10px;
        margin-bottom: 5px;
      }

      .footer-player-title {
        display: block;
        color: var(--text);
        font-size: 13px;
        font-weight: 700;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .footer-player-main {
        min-width: 0;
      }

      .footer-player iframe {
        display: block;
        width: 100%;
        height: 60px;
        border: 0;
        border-radius: 14px;
        background: #050608;
      }

      @media (max-width: 900px) {
        .sets-intro,
        .booking-cta {
          grid-template-columns: 1fr;
        }

        .profile-card {
          min-width: 0;
        }

        .sets-list {
          grid-template-columns: 1fr;
        }

        .footer-player-inner {
          grid-template-columns: 1fr;
          gap: 10px;
        }

        .footer-player-info {
          order: 1;
        }

        .footer-player-main {
          order: 2;
        }

        .player-control {
          order: 3;
          width: 100%;
          height: 42px;
        }

        .player-control[data-player-previous] {
          grid-column: auto;
        }

        .player-control[data-player-next] {
          grid-column: auto;
        }

        .footer-player-inner {
          display: grid;
          grid-template-columns: 1fr 1fr;
        }

        .footer-player-info,
        .footer-player-main {
          grid-column: 1 / -1;
        }
      }

      @media (max-width: 860px) {
        .page {
          padding: 22px 22px 230px;
        }

        header {
          align-items: flex-start;
          flex-direction: column;
          padding-bottom: 44px;
        }

        nav {
          flex-wrap: wrap;
          gap: 14px 18px;
          font-size: 12px;
        }

        .sets-list {
          margin-top: 48px;
        }

        .set-card {
          min-height: 140px;
          padding: 20px;
          border-radius: 24px;
        }

        .profile-card,
        .booking-cta {
          border-radius: 24px;
        }

        .booking-cta {
          padding: 18px;
        }

        .button {
          width: 100%;
        }

        footer {
          flex-direction: column;
        }

        .footer-player {
          bottom: 10px;
          width: calc(100% - 20px);
          border-radius: 18px;
          padding: 10px;
        }

        .footer-player-title {
          white-space: normal;
        }

        .footer-player iframe {
          height: 60px;
          border-radius: 12px;
        }
      }
    </style>
  </head>

  <body>
    <div class="page">
      <header>
        <a class="logo" href="/" aria-label="Itchy Lemon homepage">
          <img class="logo-icon" src="/favicon.png" alt="" />
          <span>Itchy Lemon</span>
        </a>

        <nav aria-label="Main navigation">
          <a href="/music">Music</a>
          <a href="/bio">Bio</a>
          <a href="/discography">Discography</a>
          <a href="/media">Media</a>
          <a href="/press-kit">Press Kit</a>
          <a class="active" href="/sets">Sets</a>
          <a href="/booking">Booking</a>
        </nav>
      </header>

      <main>
        <p class="eyebrow">DJ Sets & Radio Shows</p>

        <h1>Sets</h1>

        <div class="sets-intro">
          <p class="lead">
            Selected DJ sets, radio shows and live recordings from the Itchy Lemon archive.
          </p>

          <aside class="profile-card">
            <strong>Mixcloud Archive</strong>
            <p>
              House, Deep House, Tech House and melodic electronic journeys — curated for listening without leaving the site.
            </p>
          </aside>
        </div>

        <section class="sets-list" aria-label="Itchy Lemon DJ sets">
          {enhancedSets.map((set, index) => (
            <button
              class={`set-card ${index === 0 ? "is-active" : ""}`}
              type="button"
              data-set-card
              data-set-index={index}
            >
              <span>
                <strong>{set.title}</strong>
                <span>Load this set in the footer player</span>
              </span>

              <span class="set-card-footer">
                <span>Fresh Beats Archive</span>
                <span>Play</span>
              </span>
            </button>
          ))}
        </section>

        <section class="booking-cta" aria-label="Book Itchy Lemon">
          <div>
            <p>Like the sound?</p>
            <h2>Book Itchy Lemon</h2>
            <div class="cta-copy">
              Available for club DJ sets, guest mixes, electronic music events and selected collaborations.
            </div>
          </div>

          <a class="button" href="/booking">
            Request Booking
          </a>
        </section>
      </main>

      <footer>
        <span>© 2026 Itchy Lemon. All rights reserved.</span>
        <span>
          DJ sets · Radio shows · Mixcloud archive · Fresh Beats ·
          <a href="/privacy-policy">Privacy Policy</a>
        </span>
      </footer>
    </div>

    <div class="footer-player" aria-label="Featured Mixcloud player">
      <div class="footer-player-inner">
        <button class="player-control" type="button" data-player-previous aria-label="Previous set">
          ‹
        </button>

        <div class="footer-player-info">
          <span class="footer-player-label">Now playing</span>
          <span class="footer-player-title" data-now-playing-title>{featuredSet.title}</span>
        </div>

        <div class="footer-player-main">
          <iframe
            id="mixcloud-footer-player"
            title={`Footer player - ${featuredSet.title}`}
            width="100%"
            height="60"
            src={getEmbedUrl(featuredSet.url)}
            frameborder="0"
            allow="encrypted-media; fullscreen; web-share"
            loading="lazy"
          ></iframe>
        </div>

        <button class="player-control" type="button" data-player-next aria-label="Next set">
          ›
        </button>
      </div>
    </div>

    <script src="https://widget.mixcloud.com/media/js/widgetApi.js"></script>

    <script define:vars={{ playerSets: enhancedSets }}>
      const sets = playerSets;

      const footerIframe = document.querySelector("#mixcloud-footer-player");
      const nowPlayingTitle = document.querySelector("[data-now-playing-title]");
      const setCards = document.querySelectorAll("[data-set-card]");
      const previousButton = document.querySelector("[data-player-previous]");
      const nextButton = document.querySelector("[data-player-next]");

      let footerWidget = null;
      let currentSetIndex = 0;
      let widgetIsReady = false;

      const updateActiveSet = (index) => {
        setCards.forEach((card) => {
          card.classList.remove("is-active");
        });

        const activeCard = document.querySelector(`[data-set-index="${index}"]`);

        if (activeCard) {
          activeCard.classList.add("is-active");
        }

        if (nowPlayingTitle && sets[index]) {
          nowPlayingTitle.textContent = sets[index].title;
        }
      };

      const loadSet = (index, shouldPlay = true) => {
        if (!sets[index]) {
          return;
        }

        currentSetIndex = index;
        updateActiveSet(index);

        if (!footerWidget || !widgetIsReady) {
          return;
        }

        footerWidget.load(sets[index].key, shouldPlay);
      };

      const playNextSet = () => {
        const nextIndex = currentSetIndex + 1 < sets.length ? currentSetIndex + 1 : 0;
        loadSet(nextIndex, true);
      };

      const playPreviousSet = () => {
        const previousIndex = currentSetIndex - 1 >= 0 ? currentSetIndex - 1 : sets.length - 1;
        loadSet(previousIndex, true);
      };

      const initialiseFooterPlayer = () => {
        if (!window.Mixcloud || !window.Mixcloud.PlayerWidget || !footerIframe) {
          return;
        }

        footerWidget = window.Mixcloud.PlayerWidget(footerIframe);

        footerWidget.ready.then(() => {
          widgetIsReady = true;

          footerWidget.events.ended.on(() => {
            playNextSet();
          });
        });
      };

      setCards.forEach((card) => {
        card.addEventListener("click", () => {
          const index = Number(card.dataset.setIndex);
          loadSet(index, true);
        });
      });

      previousButton?.addEventListener("click", playPreviousSet);
      nextButton?.addEventListener("click", playNextSet);

      window.addEventListener("load", initialiseFooterPlayer);
    </script>
  </body>
</html>