---
import GlobalMixcloudPlayer from "../components/GlobalMixcloudPlayer.astro";
import HubSpotTracking from "../components/HubSpotTracking.astro";

const radioShows = [
  {
    number: "#41",
    year: "2016",
    title: "Fresh Beats Radio Show #41",
    meta: "January 2016",
    type: "Radio Show",
    url: "https://www.mixcloud.com/ITCHY_LEMON_DjProducer/itchy-lemon-fresh-beats-41-jan-2016/",
  },
  {
    number: "#40",
    year: "2015",
    title: "Fresh Beats Radio Show #40",
    meta: "Recorded live at Orange Room Porto · Studio Series Episode 108 · December 2015",
    type: "Radio Show",
    url: "https://www.mixcloud.com/ITCHY_LEMON_DjProducer/itchy-lemon-fresh-beats-40-rec-live-at-orange-room-porto-studio-series-episode-108-dec-2015/",
  },
  {
    number: "#39",
