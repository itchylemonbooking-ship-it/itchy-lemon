---
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Press kit for Itchy Lemon — artist bio, music links, booking contact and essential information for promoters, curators and collaborators."
    />
    <meta name="author" content="Itchy Lemon" />
    <meta name="theme-color" content="#07090c" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Press Kit | Itchy Lemon</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href="https://itchy-lemon.pages.dev/press-kit" />

    <style>
      :root {
        --bg: #07090c;
        --bg-soft: #10141b;
        --text: #f4f4f0;
        --muted: #a7adb8;
        --acid: #d8ff3e;
        --line: rgba(255, 255, 255, 0.12);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: Arial, Helvetica, sans-serif;
        background:
          radial-gradient(circle at top right, rgba(216, 255, 62, 0.12), transparent 34%),
          linear-gradient(135deg, #07090c 0%, #111827 48%, #050608 100%);
        color: var(--text);
        min-height: 100vh;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .page {
        min-height: 100vh;
        padding: 32px;
      }

      header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 24px;
        padding-bottom: 56px;
      }

      .logo {
        display: flex;
        align-items: center;
        gap: 10px;
        color: var(--acid);
        font-weight: 700;
        text-transform: uppercase;
        white-space: nowrap;
      }

      .logo-icon {
        display: block;
        width: 22px;
        height: 22px;
        object-fit: contain;
        flex-shrink: 0;
      }

      .logo span {
        display: inline-block;
        font-size: 14px;
        letter-spacing: 0.32em;
        line-height: 1;
      }

      nav {
        display: flex;
        gap: 22px;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--muted);
      }

      nav a:hover,
      nav a.active {
        color: var(--acid);
      }

      main {
        max-width: 1080px;
        margin: 0 auto;
      }

      .eyebrow {
        color: var(--acid);
        text-transform: uppercase;
        letter-spacing: 0.24em;
        font-size: 13px;
        margin-bottom: 18px;
      }

      h1 {
        margin: 0;
        font-size: clamp(48px, 8vw, 104px);
        line-height: 0.9;
        letter-spacing: -0.06em;
        text-transform: uppercase;
      }

      .lead {
        margin-top: 32px;
        max-width: 820px;
        font-size: clamp(22px, 3vw, 34px);
        line-height: 1.16;
      }

      .kit-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 28px;
        margin-top: 72px;
      }

      .panel {
        border: 1px solid var(--line);
        background: rgba(16, 20, 27, 0.72);
        border-radius: 28px;
        padding: 28px;
        backdrop-filter: blur(12px);
      }

      .panel.wide {
        grid-column: span 2;
      }

      .panel h2 {
        margin: 0 0 20px;
        color: var(--acid);
        font-size: 13px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }

      .panel p {
        color: var(--muted);
        font-size: 17px;
        line-height: 1.7;
        margin: 0 0 20px;
      }

      .panel strong {
        color: var(--text);
      }

      .tag-list {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 22px;
      }

      .tag {
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 9px 13px;
        color: var(--muted);
        font-size: 13px;
      }

      .link-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 24px;
        border-top: 1px solid var(--line);
        padding: 18px 0;
        color: var(--muted);
      }

      .link-row strong {
        color: var(--text);
        font-size: 20px;
      }

      .link-row span {
        color: var(--acid);
        text-transform: uppercase;
        letter-spacing: 0.16em;
        font-size: 12px;
      }

      .link-row:hover strong {
        color: var(--acid);
      }

      .facts {
        display: grid;
        gap: 16px;
        margin: 0;
        padding: 0;
        list-style: none;
      }

      .facts li {
        border-top: 1px solid var(--line);
        padding-top: 16px;
        color: var(--muted);
        line-height: 1.5;
      }

      .facts strong {
        display: block;
        color: var(--text);
        margin-bottom: 4px;
      }

      .note {
        margin-top: 20px;
        color: var(--muted);
        font-size: 14px;
        line-height: 1.6;
      }

      footer {
        max-width: 1080px;
        margin: 80px auto 0;
        color: var(--muted);
        font-size: 12px;
        padding-top: 28px;
        border-top: 1px solid var(--line);
        display: flex;
        justify-content: space-between;
        gap: 20px;
      }

      @media (max-width: 860px) {
        .page {
          padding: 22px;
        }

        header {
          align-items: flex-start;
          flex-direction: column;
        }

        nav {
          flex-wrap: wrap;
        }

        .kit-grid {
          grid-template-columns: 1fr;
          margin-top: 48px;
        }

        .panel.wide {
          grid-column: span 1;
        }

        .link-row {
          align-items: flex-start;
          flex-direction: column;
          gap: 8px;
        }

        footer {
          flex-direction: column;
        }
      }
    </style>
  </head>

  <body>
    <div class="page">
      <header>
        <a class="logo" href="/" aria-label="Itchy Lemon homepage">
          <img class="logo-icon" src="/favicon.png" alt="" />
          <span>Itchy Lemon</span>
        </a>

       <nav>
  <a href="/music">Music</a>
  <a href="/bio">Bio</a>
  <a href="/discography">Discography</a>
  <a href="/media">Media</a>
  <a href="/press-kit">Press Kit</a>
  <a href="/booking">Booking</a>
</nav>
      </header>

      <main>
        <p class="eyebrow">Electronic Press Kit</p>

        <h1>Press Kit</h1>

        <p class="lead">
          Essential artist information, music links and booking details for promoters, curators, radio shows and selected collaborators.
        </p>

        <section class="kit-grid">
          <article class="panel wide">
            <h2>Short Artist Bio</h2>

            <p>
              <strong>Itchy Lemon</strong> is a Portuguese DJ and electronic music producer with a sound shaped by melodic tension, deep groove and underground club energy.
            </p>

            <p>
              Rooted in melodic house, deep grooves and progressive electronic textures, his music moves between introspection and dancefloor energy — built with atmosphere, rhythm and emotional progression at its core.
            </p>

            <p>
              In 2026, the project is being repositioned with a renewed visual identity and a sharper digital presence, bringing Itchy Lemon closer to promoters, curators, radio shows, labels and selected collaborators.
            </p>

            <div class="tag-list">
              <span class="tag">Melodic House</span>
              <span class="tag">Deep House</span>
              <span class="tag">Progressive</span>
              <span class="tag">Underground Electronic</span>
              <span class="tag">DJ Sets</span>
              <span class="tag">Original Productions</span>
              <span class="tag">Portugal</span>
            </div>
          </article>

          <article class="panel">
            <h2>Artist Facts</h2>

            <ul class="facts">
              <li>
                <strong>Artist name</strong>
                Itchy Lemon
              </li>

              <li>
                <strong>Base</strong>
                Portugal
              </li>

              <li>
                <strong>Format</strong>
                DJ sets, guest mixes, original productions and selected collaborations
              </li>

              <li>
                <strong>Sound</strong>
                Melodic, deep, progressive and underground electronic music
              </li>

              <li>
                <strong>Booking email</strong>
                itchylemon.booking@gmail.com
              </li>
            </ul>
          </article>

          <article class="panel">
            <h2>Core Links</h2>

            <a class="link-row" href="/music">
              <strong>Music</strong>
              <span>Open</span>
            </a>

            <a class="link-row" href="/bio">
              <strong>Full Bio</strong>
              <span>Open</span>
            </a>

            <a class="link-row" href="/discography">
              <strong>Discography</strong>
              <span>Open</span>
            </a>

            <a class="link-row" href="/booking">
              <strong>Booking</strong>
              <span>Open</span>
            </a>

            <a class="link-row" href="mailto:itchylemon.booking@gmail.com">
              <strong>Email</strong>
              <span>Contact</span>
            </a>
          </article>

          <article class="panel">
            <h2>Music Platforms</h2>

            <a class="link-row" href="https://open.spotify.com/artist/5IfFyzIiz1iBO7RZUJyFen" target="_blank" rel="noreferrer">
              <strong>Spotify</strong>
              <span>Listen</span>
            </a>

            <a class="link-row" href="https://www.beatport.com/artist/itchy-lemon/339277" target="_blank" rel="noreferrer">
              <strong>Beatport</strong>
              <span>Artist page</span>
            </a>

            <a class="link-row" href="https://www.traxsource.com/artist/131494/itchy-lemon" target="_blank" rel="noreferrer">
              <strong>Traxsource</strong>
              <span>Artist page</span>
            </a>

            <a class="link-row" href="https://soundcloud.com/itchy-lemon" target="_blank" rel="noreferrer">
              <strong>SoundCloud</strong>
              <span>Listen</span>
            </a>
          </article>

          <article class="panel">
            <h2>Social & Video</h2>

            <a class="link-row" href="https://www.youtube.com/@ItchyLemonTV" target="_blank" rel="noreferrer">
              <strong>YouTube</strong>
              <span>Watch</span>
            </a>

            <a class="link-row" href="https://www.instagram.com/itchy_lemon/" target="_blank" rel="noreferrer">
              <strong>Instagram</strong>
              <span>Follow</span>
            </a>

            <a class="link-row" href="https://www.facebook.com/ItchyLemondjproducer" target="_blank" rel="noreferrer">
              <strong>Facebook</strong>
              <span>Follow</span>
            </a>

            <a class="link-row" href="https://www.linkedin.com/in/itchy-lemon" target="_blank" rel="noreferrer">
              <strong>LinkedIn</strong>
              <span>Connect</span>
            </a>

            <a class="link-row" href="https://x.com/ItchyLemon" target="_blank" rel="noreferrer">
              <strong>X</strong>
              <span>Follow</span>
            </a>
          </article>

          <article class="panel">
            <h2>Press Assets</h2>

            <p>
              Artist photos, logos, artwork and downloadable press material will be added here in the next stage.
            </p>

            <p class="note">
              Next step: add official images, logo files and a downloadable EPK pack.
            </p>
          </article>
        </section>
      </main>

      <footer>
        <span>© 2026 Itchy Lemon. All rights reserved.</span>
        <span>Official EPK · Music · Bio · Discography · Booking</span>
      </footer>
    </div>
  </body>
</html>