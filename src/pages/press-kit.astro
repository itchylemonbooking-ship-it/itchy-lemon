    <script src="https://js-eu1.hsforms.net/forms/embed/148590426.js" defer></script>

    <script>
      const epkModal = document.querySelector("[data-epk-modal]");
      const epkModalTriggers = document.querySelectorAll("[data-open-epk-modal]");
      const epkModalClose = document.querySelector("[data-close-epk-modal]");

      const openEpkModal = () => {
        epkModal.classList.add("is-open");
        epkModal.setAttribute("aria-hidden", "false");
        document.body.style.overflow = "hidden";
      };

      const closeEpkModal = () => {
        epkModal.classList.remove("is-open");
        epkModal.setAttribute("aria-hidden", "true");
        document.body.style.overflow = "";
      };

      epkModalTriggers.forEach((trigger) => {
        trigger.addEventListener("click", (event) => {
          event.preventDefault();
          openEpkModal();
        });
      });

      epkModalClose?.addEventListener("click", closeEpkModal);

      epkModal?.addEventListener("click", (event) => {
        if (event.target === epkModal) {
          closeEpkModal();
        }
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && epkModal.classList.contains("is-open")) {
          closeEpkModal();
        }
      });
    </script>
  </body>
</html>