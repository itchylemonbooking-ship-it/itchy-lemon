---
import SiteHeader from "../components/SiteHeader.astro";
import GlobalMixcloudPlayer from "../components/GlobalMixcloudPlayer.astro";
import HubSpotTracking from "../components/HubSpotTracking.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Music by Itchy Lemon — original productions, releases, remixes and official links on Spotify, Apple Music, Beatport, Traxsource, SoundCloud and YouTube."
    />
    <meta name="author" content="Itchy Lemon" />
    <meta name="theme-color" content="#07090c" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Music | Itchy Lemon</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href="https://itchy-lemon.pages.dev/music/" />

    <style>
      :root {
        --bg: #07090c;
        --bg-soft: #10141b;
        --text: #f4f4f0;
        --muted: #a7adb8;
        --acid: #d8ff3e;
        --line: rgba(255, 255, 255, 0.12);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: Arial, Helvetica, sans-serif;
        background:
          radial-gradient(circle at top right, rgba(216, 255, 62, 0.12), transparent 34%),
          linear-gradient(135deg, #07090c 0%, #111827 48%, #050608 100%);
        color: var(--text);
        min-height: 100vh;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      button {
        font: inherit;
      }

      .page {
        min-height: 100vh;
        padding: 32px;
      }

      main {
        max-width: 1080px;
        margin: 0 auto;
      }

      .eyebrow {
        color: var(--acid);
        text-transform: uppercase;
        letter-spacing: 0.24em;
        font-size: 13px;
        margin-bottom: 18px;
      }

      h1 {
        margin: 0;
        font-size: clamp(48px, 8vw, 104px);
        line-height: 0.9;
        letter-spacing: -0.06em;
        text-transform: uppercase;
      }

      .lead {
        margin-top: 32px;
        max-width: 780px;
        font-size: clamp(22px, 3vw, 34px);
        line-height: 1.16;
        color: var(--text);
      }

      .music-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 22px;
        margin-top: 72px;
      }

      .card {
        border: 1px solid var(--line);
        background: rgba(16, 20, 27, 0.72);
        border-radius: 28px;
        padding: 28px;
        min-height: 250px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        backdrop-filter: blur(12px);
        transition: 0.2s ease;
      }

      .card:hover {
        transform: translateY(-4px);
        border-color: rgba(216, 255, 62, 0.6);
      }

      .card-label {
        color: var(--acid);
        text-transform: uppercase;
        letter-spacing: 0.18em;
        font-size: 12px;
        margin-bottom: 18px;
      }

      .card h2 {
        margin: 0;
        font-size: 30px;
        line-height: 1;
        letter-spacing: -0.04em;
      }

      .card p {
        margin: 18px 0 0;
        color: var(--muted);
        line-height: 1.6;
        font-size: 15px;
      }

      .music-cta {
        margin-top: 48px;
        border: 1px solid var(--line);
        border-radius: 28px;
        background:
          linear-gradient(135deg, rgba(216, 255, 62, 0.1), transparent),
          rgba(16, 20, 27, 0.72);
        padding: 30px;
        backdrop-filter: blur(12px);
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 28px;
        align-items: center;
      }

      .music-cta p {
        margin: 0;
        max-width: 720px;
        color: var(--muted);
        font-size: 17px;
        line-height: 1.7;
      }

      .music-cta strong {
        color: var(--text);
      }

      .cta-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        justify-content: flex-end;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 48px;
        padding: 0 22px;
        border-radius: 999px;
        border: 1px solid var(--line);
        color: var(--text);
        font-size: 13px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        white-space: nowrap;
        transition:
          transform 0.2s ease,
          background 0.2s ease,
          border-color 0.2s ease;
      }

      .button.primary {
        background: var(--acid);
        color: #050608;
        border-color: var(--acid);
      }

      .button:hover {
        transform: translateY(-2px);
        border-color: var(--acid);
      }

      .link-list {
        display: grid;
        gap: 14px;
        margin-top: 72px;
      }

      .section-label {
        color: var(--acid);
        text-transform: uppercase;
        letter-spacing: 0.18em;
        font-size: 13px;
        margin: 0 0 8px;
      }

      .music-link {
        display: flex;
        justify-content: space-between;
        gap: 24px;
        align-items: center;
        border-top: 1px solid var(--line);
        padding: 20px 0;
        color: var(--muted);
      }

      .music-link strong {
        color: var(--text);
        font-size: 20px;
      }

      .music-link span {
        color: var(--acid);
        text-transform: uppercase;
        letter-spacing: 0.16em;
        font-size: 12px;
      }

      .music-link:hover strong {
        color: var(--acid);
      }

      footer {
        max-width: 1080px;
        margin: 80px auto 0;
        color: var(--muted);
        font-size: 12px;
        padding-top: 28px;
        border-top: 1px solid var(--line);
        display: flex;
        justify-content: space-between;
        gap: 20px;
      }

      footer a {
        color: var(--muted);
      }

      footer a:hover {
        color: var(--acid);
      }

      @media (max-width: 1024px) {
        .page {
          padding: 22px;
        }

        .music-link {
          align-items: flex-start;
          flex-direction: column;
          gap: 8px;
        }

        .button {
          width: 100%;
        }

        footer {
          flex-direction: column;
        }
      }

      @media (max-width: 900px) {
        .music-grid,
        .music-cta {
          grid-template-columns: 1fr;
        }

        .cta-actions {
          justify-content: flex-start;
        }
      }
    </style>
  </head>

  <body>
    <div class="page">
      <SiteHeader activePage="music" />

      <main>
        <p class="eyebrow">Original Music & Releases</p>

        <h1>Music</h1>

        <p class="lead">
          Original productions, releases, remixes and official music platforms from Itchy Lemon.
        </p>

        <section class="music-grid">
          <article class="card">
            <div>
              <p class="card-label">Originals</p>
              <h2>Electronic productions</h2>
              <p>
                Tracks shaped around groove, emotional progression, repetition and underground club dynamics.
              </p>
            </div>
          </article>

          <article class="card">
            <div>
              <p class="card-label">Releases</p>
              <h2>Catalogue archive</h2>
              <p>
                A selected archive of original releases, remixes and collaborations from the Itchy Lemon catalogue.
              </p>
            </div>
          </article>

          <article class="card">
            <div>
              <p class="card-label">Platforms</p>
              <h2>Official links</h2>
              <p>
                Listen, verify and explore the project through official music platforms and artist pages.
              </p>
            </div>
          </article>
        </section>

        <section class="music-cta" aria-label="DJ sets and booking">
          <p>
            Looking for <strong>DJ sets, mixes or booking availability?</strong> Explore selected Itchy Lemon sets or send a booking request directly.
          </p>

          <div class="cta-actions">
            <a class="button primary" href="/sets">Explore Sets</a>
            <a class="button" href="/booking">Request Booking</a>
          </div>
        </section>

        <section class="link-list" aria-label="Music platforms and official links">
          <p class="section-label">Official Music Links</p>

          <a class="music-link" href="https://open.spotify.com/artist/5IfFyzIiz1iBO7RZUJyFen" target="_blank" rel="noreferrer">
            <strong>Spotify</strong>
            <span>Listen</span>
          </a>

          <a class="music-link" href="https://itunes.apple.com/ph/artist/itchy-lemon/id656922930" target="_blank" rel="noreferrer">
            <strong>Apple Music / iTunes</strong>
            <span>Listen</span>
          </a>

          <a class="music-link" href="https://www.beatport.com/artist/itchy-lemon/339277" target="_blank" rel="noreferrer">
            <strong>Beatport</strong>
            <span>Artist page</span>
          </a>

          <a class="music-link" href="https://www.traxsource.com/artist/131494/itchy-lemon" target="_blank" rel="noreferrer">
            <strong>Traxsource</strong>
            <span>Artist page</span>
          </a>

          <a class="music-link" href="https://soundcloud.com/itchy-lemon" target="_blank" rel="noreferrer">
            <strong>SoundCloud</strong>
            <span>Listen</span>
          </a>

          <a class="music-link" href="https://www.youtube.com/@ItchyLemonTV" target="_blank" rel="noreferrer">
            <strong>YouTube</strong>
            <span>Watch</span>
          </a>

          <a class="music-link" href="/discography">
            <strong>Discography</strong>
            <span>View</span>
          </a>

          <a class="music-link" href="/press-kit">
            <strong>Press Kit</strong>
            <span>EPK</span>
          </a>
        </section>
      </main>

      <footer>
        <span>© 2026 Itchy Lemon. All rights reserved.</span>
        <span>
          Originals · Releases · Remixes · Music platforms · Booking ·
          <a href="/privacy-policy">Privacy Policy</a>
        </span>
      </footer>
    </div>

    <GlobalMixcloudPlayer />
    <HubSpotTracking />
  </body>
</html>