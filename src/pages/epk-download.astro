            </a>

            <a class="button" href="/sets">
              Listen to Sets
            </a>
          </div>
        </section>
      </main>

      <footer>
        <span>© 2026 Itchy Lemon. All rights reserved.</span>
        <span>Official EPK · Booking · DJ sets · Press material</span>
      </footer>
    </div>
