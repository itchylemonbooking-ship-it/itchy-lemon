---
const tracks = [
  {
    label: "Single",
    title: "New Age",
    meta: "Melodic House & Techno · 120 BPM · Preview version",
    price: "€2.49",
    cover: "/store/new-age-cover.png",
    preview: "/audio/previews/new-age-preview.mp3",
    buyUrl: "#",
    listenUrl: "#",
  },
  {
    label: "Coming Soon",
    title: "Next Release",
    meta: "Dark / Melodic / Progressive · Preview coming soon",
    price: "€2.49",
    cover: "/store/new-age-cover.png",
    preview: "/audio/previews/new-age-preview.mp3",
    buyUrl: "#",
    listenUrl: "#",
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Private preview store for Itchy Lemon — original tracks, audio previews and selected electronic music releases."
    />
    <meta name="author" content="Itchy Lemon" />
    <meta name="theme-color" content="#07090c" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />

    <title>Store Preview | Itchy Lemon</title>

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href="https://itchy-lemon.pages.dev/store/" />

    <style>
      :root {
        --bg: #07090c;
        --bg-soft: #10141b;
        --text: #f4f4f0;
        --muted: #a7adb8;
        --acid: #d8ff3e;
        --line: rgba(255, 255, 255, 0.12);
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: Arial, Helvetica, sans-serif;
        background:
          radial-gradient(circle at top right, rgba(216, 255, 62, 0.12), transparent 34%),
          linear-gradient(135deg, #07090c 0%, #111827 48%, #050608 100%);
        color: var(--text);
        min-height: 100vh;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      button {
        font: inherit;
      }

      img {
        max-width: 100%;
      }

      .page {
        min-height: 100vh;
        padding: 32px;
      }

      header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 24px;
        padding-bottom: 56px;
      }

      .logo {
        display: flex;
        align-items: center;
        gap: 10px;
        color: var(--acid);
        font-weight: 700;
        text-transform: uppercase;
        white-space: nowrap;
      }

      .logo-icon {
        display: block;
        width: 22px;
        height: 22px;
        object-fit: contain;
        flex-shrink: 0;
      }

      .logo span {
        display: inline-block;
        font-size: 14px;
        letter-spacing: 0.32em;
        line-height: 1;
      }

      nav {
        display: flex;
        gap: 22px;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--muted);
      }

      nav a {
        transition: color 0.2s ease;
      }

      nav a:hover {
        color: var(--acid);
      }

      main {
        max-width: 1080px;
        margin: 0 auto;
      }

      .eyebrow {
        color: var(--acid);
        text-transform: uppercase;
        letter-spacing: 0.24em;
        font-size: 13px;
        margin: 0 0 18px;
      }

      h1 {
        margin: 0;
        font-size: clamp(48px, 8vw, 104px);
        line-height: 0.9;
        letter-spacing: -0.06em;
        text-transform: uppercase;
      }

      .lead {
        margin: 32px 0 0;
        max-width: 780px;
        font-size: clamp(22px, 3vw, 34px);
        line-height: 1.16;
        color: var(--text);
      }

      .private-note {
        margin-top: 42px;
        border: 1px solid var(--line);
        border-radius: 28px;
        background:
          linear-gradient(135deg, rgba(216, 255, 62, 0.08), transparent),
          rgba(16, 20, 27, 0.72);
        padding: 24px;
        color: var(--muted);
        font-size: 15px;
        line-height: 1.7;
        backdrop-filter: blur(12px);
      }

      .private-note strong {
        color: var(--acid);
      }

      .store-list {
        display: grid;
        gap: 22px;
        margin-top: 64px;
      }

      .track-card {
        display: grid;
        grid-template-columns: 180px 1fr auto;
        gap: 24px;
        align-items: center;
        border: 1px solid var(--line);
        border-radius: 28px;
        background: rgba(16, 20, 27, 0.72);
        padding: 20px;
        backdrop-filter: blur(12px);
        box-shadow: 0 24px 80px rgba(0, 0, 0, 0.24);
      }

      .track-cover {
        width: 180px;
        aspect-ratio: 1 / 1;
        border-radius: 22px;
        overflow: hidden;
        background:
          linear-gradient(135deg, rgba(216, 255, 62, 0.12), transparent),
          rgba(255, 255, 255, 0.04);
        border: 1px solid var(--line);
      }

      .track-cover img {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .track-info {
        min-width: 0;
      }

      .track-label {
        margin: 0 0 12px;
        color: var(--acid);
        text-transform: uppercase;
        letter-spacing: 0.18em;
        font-size: 12px;
      }

      .track-title {
        margin: 0;
        font-size: clamp(30px, 4vw, 46px);
        line-height: 0.95;
        letter-spacing: -0.05em;
        text-transform: uppercase;
      }

      .track-meta {
        margin: 16px 0 0;
        color: var(--muted);
        font-size: 15px;
        line-height: 1.6;
      }

      .custom-player {
        display: grid;
        grid-template-columns: 46px 1fr auto;
        gap: 14px;
        align-items: center;
        margin-top: 22px;
        padding: 14px;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: rgba(7, 9, 12, 0.46);
      }

      .play-button {
        width: 46px;
        height: 46px;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: rgba(216, 255, 62, 0.08);
        color: var(--acid);
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        transition:
          border-color 0.2s ease,
          background 0.2s ease,
          transform 0.2s ease;
      }

      .play-button:hover {
        border-color: var(--acid);
        background: rgba(216, 255, 62, 0.14);
        transform: translateY(-1px);
      }

      .progress-wrap {
        display: grid;
        gap: 8px;
      }

      .progress-bar {
        width: 100%;
        accent-color: var(--acid);
        cursor: pointer;
      }

      .time-row {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        color: var(--muted);
        font-size: 12px;
        letter-spacing: 0.08em;
      }

      .player-status {
        color: var(--acid);
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        white-space: nowrap;
      }

      .track-side {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 14px;
        min-width: 150px;
      }

      .price {
        color: var(--text);
        font-size: 24px;
        font-weight: 700;
        letter-spacing: -0.04em;
      }

      .track-actions {
        display: flex;
        flex-direction: column;
        gap: 10px;
        width: 100%;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 44px;
        padding: 0 18px;
        border-radius: 999px;
        border: 1px solid var(--line);
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        transition:
          border-color 0.2s ease,
          background 0.2s ease,
          color 0.2s ease,
          transform 0.2s ease;
        white-space: nowrap;
      }

      .button:hover {
        transform: translateY(-1px);
      }

      .button-primary {
        background: var(--acid);
        color: #07090c;
        border-color: var(--acid);
        font-weight: 700;
      }

      .button-secondary {
        color: var(--acid);
        background: rgba(216, 255, 62, 0.06);
      }

      .button-secondary:hover {
        border-color: var(--acid);
      }

      .store-note {
        margin-top: 48px;
        border-left: 2px solid var(--acid);
        padding-left: 22px;
        color: var(--muted);
        font-size: 17px;
        line-height: 1.7;
        max-width: 820px;
      }

      footer {
        max-width: 1080px;
        margin: 80px auto 0;
        color: var(--muted);
        font-size: 12px;
        padding-top: 28px;
        border-top: 1px solid var(--line);
        display: flex;
        justify-content: space-between;
        gap: 20px;
      }

      footer a {
        color: var(--muted);
      }

      footer a:hover {
        color: var(--acid);
      }

      @media (max-width: 980px) {
        .track-card {
          grid-template-columns: 150px 1fr;
        }

        .track-cover {
          width: 150px;
        }

        .track-side {
          grid-column: 2;
          align-items: flex-start;
          min-width: 0;
        }

        .track-actions {
          flex-direction: row;
          flex-wrap: wrap;
        }
      }

      @media (max-width: 860px) {
        .page {
          padding: 22px;
        }

        header {
          align-items: flex-start;
          flex-direction: column;
        }

        nav {
          flex-wrap: wrap;
        }

        .store-list {
          margin-top: 48px;
        }

        .track-card {
          grid-template-columns: 1fr;
          gap: 18px;
          border-radius: 24px;
        }

        .track-cover {
          width: 100%;
          border-radius: 20px;
        }

        .track-side {
          grid-column: auto;
        }

        .track-actions {
          width: 100%;
        }

        .button {
          flex: 1;
        }

        footer {
          flex-direction: column;
        }
      }

      @media (max-width: 620px) {
        .custom-player {
          grid-template-columns: 46px 1fr;
          border-radius: 24px;
        }

        .player-status {
          grid-column: 1 / -1;
          padding-left: 4px;
        }
      }

      @media (max-width: 520px) {
        .track-actions {
          flex-direction: column;
        }

        .button {
          width: 100%;
        }
      }
    </style>
  </head>

  <body>
    <div class="page">
      <header>
        <a class="logo" href="/" aria-label="Itchy Lemon homepage">
          <img class="logo-icon" src="/favicon.png" alt="" />
          <span>Itchy Lemon</span>
        </a>

        <nav aria-label="Main navigation">
          <a href="/music">Music</a>
          <a href="/bio">Bio</a>
          <a href="/discography">Discography</a>
          <a href="/media">Media</a>
          <a href="/press-kit">Press Kit</a>
          <a href="/sets">Sets</a>
          <a href="/booking">Booking</a>
        </nav>
      </header>

      <main>
        <p class="eyebrow">Private Store Preview</p>

        <h1>Store</h1>

        <p class="lead">
          Listen to selected previews and prepare original Itchy Lemon tracks for future direct purchase.
        </p>

        <section class="private-note" aria-label="Private store status">
          <strong>Private preview page.</strong>
          This store is currently hidden from the public menu and search engines. Purchase links, final artworks, previews, delivery settings and refund policy will be connected later.
        </section>

        <section class="store-list" aria-label="Itchy Lemon tracks for sale">
          {tracks.map((track) => (
            <article class="track-card">
              <div class="track-cover">
                <img src={track.cover} alt={`${track.title} artwork`} />
              </div>

              <div class="track-info">
                <p class="track-label">{track.label}</p>
                <h2 class="track-title">{track.title}</h2>
                <p class="track-meta">{track.meta}</p>

                <div class="custom-player" data-player>
                  <audio preload="metadata" src={track.preview}></audio>

                  <button
                    class="play-button"
                    type="button"
                    data-play
                    aria-label={`Play preview of ${track.title}`}
                  >
                    ▶
                  </button>

                  <div class="progress-wrap">
                    <input
                      class="progress-bar"
                      type="range"
                      min="0"
                      max="1000"
                      value="0"
                      step="1"
                      data-progress
                      aria-label={`Preview progress for ${track.title}`}
                    />

                    <div class="time-row">
                      <span data-current>0:00</span>
                      <span data-duration>0:00</span>
                    </div>
                  </div>

                  <span class="player-status" data-status>
                    Preview
                  </span>
                </div>
              </div>

              <div class="track-side">
                <span class="price">{track.price}</span>

                <div class="track-actions">
                  <a class="button button-primary" href={track.buyUrl} aria-label={`Buy ${track.title}`}>
                    Buy Track
                  </a>
                  <a class="button button-secondary" href={track.listenUrl} aria-label={`Listen to ${track.title}`}>
                    Listen
                  </a>
                </div>
              </div>
            </article>
          ))}
        </section>

        <p class="store-note">
          Full downloads and purchase links will be connected later through Payhip, Gumroad, Stripe, Bandcamp or another checkout solution. For now, this page is prepared for previews, track metadata and future external checkout links.
        </p>
      </main>

      <footer>
        <span>© 2026 Itchy Lemon. All rights reserved.</span>
        <span>
          Private store preview · Original tracks · Previews · Downloads ·
          <a href="/privacy-policy">Privacy Policy</a>
        </span>
      </footer>
    </div>

    <script>
      const players = document.querySelectorAll("[data-player]");

      const formatTime = (seconds) => {
        if (!Number.isFinite(seconds)) return "0:00";

        const minutes = Math.floor(seconds / 60);
        const remainingSeconds = Math.floor(seconds % 60)
          .toString()
          .padStart(2, "0");

        return `${minutes}:${remainingSeconds}`;
      };

      const pauseOtherPlayers = (currentAudio) => {
        players.forEach((player) => {
          const audio = player.querySelector("audio");
          const playButton = player.querySelector("[data-play]");
          const status = player.querySelector("[data-status]");

          if (audio !== currentAudio) {
            audio.pause();
            playButton.textContent = "▶";
            status.textContent = "Preview";
          }
        });
      };

      players.forEach((player) => {
        const audio = player.querySelector("audio");
        const playButton = player.querySelector("[data-play]");
        const progress = player.querySelector("[data-progress]");
        const currentTime = player.querySelector("[data-current]");
        const duration = player.querySelector("[data-duration]");
        const status = player.querySelector("[data-status]");

        audio.addEventListener("loadedmetadata", () => {
          duration.textContent = formatTime(audio.duration);
        });

        playButton.addEventListener("click", () => {
          if (audio.paused) {
            pauseOtherPlayers(audio);
            audio.play();
            playButton.textContent = "❚❚";
            status.textContent = "Playing";
          } else {
            audio.pause();
            playButton.textContent = "▶";
            status.textContent = "Paused";
          }
        });

        audio.addEventListener("timeupdate", () => {
          if (audio.duration) {
            progress.value = (audio.currentTime / audio.duration) * 1000;
          }

          currentTime.textContent = formatTime(audio.currentTime);
        });

        progress.addEventListener("input", () => {
          if (audio.duration) {
            audio.currentTime = (progress.value / 1000) * audio.duration;
          }
        });

        audio.addEventListener("ended", () => {
          playButton.textContent = "▶";
          status.textContent = "Preview";
          progress.value = 0;
          currentTime.textContent = "0:00";
        });
      });
    </script>
  </body>
</html>