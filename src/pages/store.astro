<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Itchy Lemon Store — original tracks, previews and selected electronic music releases."
    />
    <meta name="author" content="Itchy Lemon" />
    <meta name="theme-color" content="#07090c" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Store | Itchy Lemon</title>

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href="https://itchy-lemon.pages.dev/store/" />

    <style>
      :root {
        --bg: #07090c;
        --bg-soft: #10141b;
        --text: #f4f4f0;
        --muted: #a7adb8;
        --acid: #d8ff3e;
        --line: rgba(255, 255, 255, 0.12);
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: Arial, Helvetica, sans-serif;
        background:
          radial-gradient(circle at top right, rgba(216, 255, 62, 0.12), transparent 34%),
          linear-gradient(135deg, #07090c 0%, #111827 48%, #050608 100%);
        color: var(--text);
        min-height: 100vh;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        max-width: 100%;
      }

      .page {
        min-height: 100vh;
        padding: 32px;
      }

      header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 24px;
        padding-bottom: 56px;
      }

      .logo {
        display: flex;
        align-items: center;
        gap: 10px;
        color: var(--acid);
        font-weight: 700;
        text-transform: uppercase;
        white-space: nowrap;
      }

      .logo-icon {
        display: block;
        width: 22px;
        height: 22px;
        object-fit: contain;
        flex-shrink: 0;
      }

      .logo span {
        display: inline-block;
        font-size: 14px;
        letter-spacing: 0.32em;
        line-height: 1;
      }

      nav {
        display: flex;
        gap: 22px;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--muted);
      }

      nav a {
        transition: color 0.2s ease;
      }

      nav a:hover,
      nav a.active {
        color: var(--acid);
      }

      main {
        max-width: 1080px;
        margin: 0 auto;
      }

      .eyebrow {
        color: var(--acid);
        text-transform: uppercase;
        letter-spacing: 0.24em;
        font-size: 13px;
        margin: 0 0 18px;
      }

      h1 {
        margin: 0;
        font-size: clamp(48px, 8vw, 104px);
        line-height: 0.9;
        letter-spacing: -0.06em;
        text-transform: uppercase;
      }

      .lead {
        margin: 32px 0 0;
        max-width: 840px;
        font-size: clamp(22px, 3vw, 34px);
        line-height: 1.16;
        color: var(--text);
      }

      .store-list {
        display: grid;
        gap: 22px;
        margin-top: 64px;
      }

      .track-card {
        display: grid;
        grid-template-columns: 180px 1fr auto;
        gap: 24px;
        align-items: center;
        border: 1px solid var(--line);
        border-radius: 28px;
        background: rgba(16, 20, 27, 0.72);
        padding: 20px;
        backdrop-filter: blur(12px);
        box-shadow: 0 24px 80px rgba(0, 0, 0, 0.24);
      }

      .track-cover {
        width: 180px;
        aspect-ratio: 1 / 1;
        border-radius: 22px;
        overflow: hidden;
        background:
          linear-gradient(135deg, rgba(216, 255, 62, 0.12), transparent),
          rgba(255, 255, 255, 0.04);
        border: 1px solid var(--line);
      }

      .track-cover img {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .track-info {
        min-width: 0;
      }

      .track-label {
        margin: 0 0 12px;
        color: var(--acid);
        text-transform: uppercase;
        letter-spacing: 0.18em;
        font-size: 12px;
      }

      .track-title {
        margin: 0;
        font-size: clamp(30px, 4vw, 46px);
        line-height: 0.95;
        letter-spacing: -0.05em;
        text-transform: uppercase;
      }

      .track-meta {
        margin: 16px 0 0;
        color: var(--muted);
        font-size: 15px;
        line-height: 1.6;
      }

      .track-player {
        margin-top: 20px;
      }

      audio {
        width: 100%;
        accent-color: var(--acid);
      }

      .track-side {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 14px;
        min-width: 150px;
      }

      .price {
        color: var(--text);
        font-size: 24px;
        font-weight: 700;
        letter-spacing: -0.04em;
      }

      .track-actions {
        display: flex;
        flex-direction: column;
        gap: 10px;
        width: 100%;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 44px;
        padding: 0 18px;
        border-radius: 999px;
        border: 1px solid var(--line);
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        transition:
          border-color 0.2s ease,
          background 0.2s ease,
          color 0.2s ease,
          transform 0.2s ease;
        white-space: nowrap;
      }

      .button:hover {
        transform: translateY(-1px);
      }

      .button-primary {
        background: var(--acid);
        color: #07090c;
        border-color: var(--acid);
        font-weight: 700;
      }

      .button-secondary {
        color: var(--acid);
        background: rgba(216, 255, 62, 0.06);
      }

      .button-secondary:hover {
        border-color: var(--acid);
      }

      .store-note {
        margin-top: 48px;
        border-left: 2px solid var(--acid);
        padding-left: 22px;
        color: var(--muted);
        font-size: 17px;
        line-height: 1.7;
        max-width: 820px;
      }

      footer {
        max-width: 1080px;
        margin: 80px auto 0;
        color: var(--muted);
        font-size: 12px;
        padding-top: 28px;
        border-top: 1px solid var(--line);
        display: flex;
        justify-content: space-between;
        gap: 20px;
      }

      @media (max-width: 980px) {
        .track-card {
          grid-template-columns: 150px 1fr;
        }

        .track-cover {
          width: 150px;
        }

        .track-side {
          grid-column: 2;
          align-items: flex-start;
          min-width: 0;
        }

        .track-actions {
          flex-direction: row;
          flex-wrap: wrap;
        }
      }

      @media (max-width: 860px) {
        .page {
          padding: 22px;
        }

        header {
          align-items: flex-start;
          flex-direction: column;
          padding-bottom: 44px;
        }

        nav {
          flex-wrap: wrap;
          gap: 14px 18px;
          font-size: 12px;
        }

        .store-list {
          margin-top: 48px;
        }

        .track-card {
          grid-template-columns: 1fr;
          gap: 18px;
          border-radius: 24px;
        }

        .track-cover {
          width: 100%;
          border-radius: 20px;
        }

        .track-side {
          grid-column: auto;
        }

        .track-actions {
          width: 100%;
        }

        .button {
          flex: 1;
        }

        footer {
          flex-direction: column;
        }
      }

      @media (max-width: 520px) {
        .track-actions {
          flex-direction: column;
        }

        .button {
          width: 100%;
        }
      }
    </style>
  </head>

  <body>
    <div class="page">
      <header>
        <a class="logo" href="/" aria-label="Itchy Lemon homepage">
          <img class="logo-icon" src="/favicon.png" alt="" />
          <span>Itchy Lemon</span>
        </a>

        <nav aria-label="Main navigation">
          <a href="/music">Music</a>
          <a href="/bio">Bio</a>
          <a href="/discography">Discography</a>
          <a href="/media">Media</a>
          <a href="/press-kit">Press Kit</a>
          <a class="active" href="/store">Store</a>
          <a href="/booking">Booking</a>
        </nav>
      </header>

      <main>
        <p class="eyebrow">Original Tracks & Releases</p>

        <h1>Store</h1>

        <p class="lead">
          Listen to selected previews and buy original Itchy Lemon tracks directly from the official store.
        </p>

        <section class="store-list" aria-label="Itchy Lemon tracks for sale">
          <article class="track-card">
            <div class="track-cover">
              <img src="/store/new-age-cover.png" alt="New Age artwork" />
            </div>

            <div class="track-info">
              <p class="track-label">Single</p>
              <h2 class="track-title">New Age</h2>
              <p class="track-meta">
                Melodic House & Techno · 120 BPM · Preview version
              </p>

              <div class="track-player">
                <audio controls preload="none">
                  <source src="/audio/previews/new-age-preview.mp3" type="audio/mpeg" />
                  Your browser does not support the audio element.
                </audio>
              </div>
            </div>

            <div class="track-side">
              <span class="price">€2.49</span>

              <div class="track-actions">
                <a class="button button-primary" href="#" aria-label="Buy New Age">
                  Buy Track
                </a>
                <a class="button button-secondary" href="#" aria-label="Listen to New Age">
                  Listen
                </a>
              </div>
            </div>
          </article>

          <article class="track-card">
            <div class="track-cover">
              <img src="/store/new-age-cover.png" alt="Next Release artwork" />
            </div>

            <div class="track-info">
              <p class="track-label">Coming Soon</p>
              <h2 class="track-title">Next Release</h2>
              <p class="track-meta">
                Dark / Melodic / Progressive · Preview coming soon
              </p>

              <div class="track-player">
                <audio controls preload="none">
                  <source src="/audio/previews/new-age-preview.mp3" type="audio/mpeg" />
                  Your browser does not support the audio element.
                </audio>
              </div>
            </div>

            <div class="track-side">
              <span class="price">€2.49</span>

              <div class="track-actions">
                <a class="button button-primary" href="#" aria-label="Buy next release">
                  Buy Track
                </a>
                <a class="button button-secondary" href="#" aria-label="Listen to next release">
                  Listen
                </a>
              </div>
            </div>
          </article>
        </section>

        <p class="store-note">
          Full downloads and purchase links will be connected soon. For now, this page is prepared for previews, track information and external checkout links.
        </p>
      </main>

      <footer>
        <span>© 2026 Itchy Lemon. All rights reserved.</span>
        <span>Original tracks · Previews · Downloads · Store</span>
      </footer>
    </div>
  </body>
</html>