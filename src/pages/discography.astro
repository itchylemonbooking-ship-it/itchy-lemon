---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Discography of Itchy Lemon — selected electronic music releases from Beatport, Traxsource, Juno Download, Amazon Music and Apple Music."
    />
    <meta name="author" content="Itchy Lemon" />
    <meta name="theme-color" content="#07090c" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Discography | Itchy Lemon</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href="https://itchy-lemon.pages.dev/discography/" />

    <style>
      :root {
        --bg: #07090c;
        --bg-soft: #10141b;
        --text: #f4f4f0;
        --muted: #a7adb8;
        --acid: #d8ff3e;
        --line: rgba(255, 255, 255, 0.12);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: Arial, Helvetica, sans-serif;
        background:
          radial-gradient(circle at top right, rgba(216, 255, 62, 0.12), transparent 34%),
          linear-gradient(135deg, #07090c 0%, #111827 48%, #050608 100%);
        color: var(--text);
        min-height: 100vh;
      }

      body.beatport-preview-visible .page {
        padding-bottom: 114px;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .page {
        min-height: 100vh;
        padding: 32px;
      }

      header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 24px;
        padding-bottom: 56px;
      }

      .logo {
        display: flex;
        align-items: center;
        gap: 10px;
        color: var(--acid);
        font-weight: 700;
        text-transform: uppercase;
        white-space: nowrap;
      }

      .logo-icon {
        display: block;
        width: 22px;
        height: 22px;
        object-fit: contain;
        flex-shrink: 0;
      }

      .logo span {
        display: inline-block;
        font-size: 14px;
        letter-spacing: 0.32em;
        line-height: 1;
      }

      nav {
        display: flex;
        gap: 22px;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--muted);
      }

      nav a:hover,
      nav a.active {
        color: var(--acid);
      }

      main {
        max-width: 1080px;
        margin: 0 auto;
      }

      .eyebrow {
        color: var(--acid);
        text-transform: uppercase;
        letter-spacing: 0.24em;
        font-size: 13px;
        margin-bottom: 18px;
      }

      h1 {
        margin: 0;
        font-size: clamp(48px, 8vw, 104px);
        line-height: 0.9;
        letter-spacing: -0.06em;
        text-transform: uppercase;
      }

      .lead {
        margin-top: 32px;
        max-width: 780px;
        font-size: clamp(22px, 3vw, 34px);
        line-height: 1.16;
        color: var(--text);
      }

      .release-list {
        display: grid;
        gap: 0;
        margin-top: 64px;
      }

      .release {
        display: grid;
        grid-template-columns: 80px 44px 1fr 180px 260px;
        gap: 18px;
        align-items: start;
        border-top: 1px solid var(--line);
        padding: 24px 0;
      }

      .year {
        color: var(--acid);
        font-size: 14px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        padding-top: 8px;
      }

      .play-cell {
        display: flex;
        justify-content: flex-start;
        align-items: flex-start;
      }

      .release h2 {
        margin: 0;
        font-size: 26px;
        line-height: 1.05;
        letter-spacing: -0.04em;
      }

      .release p {
        margin: 9px 0 0;
        color: var(--muted);
        font-size: 15px;
        line-height: 1.55;
      }

      .label {
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.14em;
        font-size: 12px;
        line-height: 1.45;
        padding-top: 8px;
      }

      .release-actions {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        align-items: flex-start;
        flex-wrap: wrap;
      }

      .store-links {
        display: flex;
        justify-content: flex-end;
        gap: 8px;
        align-items: center;
        flex-wrap: wrap;
      }

      .store-link,
      .preview-button {
        border: 1px solid var(--line);
        color: var(--muted);
        background: transparent;
        font-family: inherit;
        cursor: pointer;
        transition: 0.2s ease;
      }

      .store-link {
        border-radius: 999px;
        padding: 9px 12px;
        font-size: 10px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        white-space: nowrap;
      }

      .preview-button {
        width: 34px;
        height: 34px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        padding: 0;
        color: var(--acid);
        font-size: 13px;
        line-height: 1;
        flex-shrink: 0;
      }

      .preview-button span {
        display: block;
        transform: translateX(1px);
      }

      .store-link:hover,
      .preview-button:hover,
      .preview-button.is-active {
        color: #050608;
        background: var(--acid);
        border-color: var(--acid);
        transform: translateY(-2px);
      }

      .preview-button:hover span,
      .preview-button.is-active span {
        color: #050608;
      }

      .no-preview {
        width: 34px;
        height: 34px;
      }

      .catalogue-card {
        margin-top: 48px;
        border: 1px solid var(--line);
        background: rgba(16, 20, 27, 0.72);
        border-radius: 28px;
        padding: 28px;
        display: grid;
        grid-template-columns: 1fr;
        gap: 24px;
        align-items: center;
        backdrop-filter: blur(12px);
      }

      .catalogue-card h2 {
        margin: 0;
        font-size: 30px;
        letter-spacing: -0.04em;
      }

      .catalogue-card p {
        margin: 12px 0 0;
        color: var(--muted);
        font-size: 16px;
        line-height: 1.6;
      }

      .catalogue-links {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }

      .button {
        display: inline-block;
        background: var(--acid);
        color: #050608;
        border-radius: 999px;
        padding: 15px 22px;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        white-space: nowrap;
      }

      .button.secondary {
        background: transparent;
        color: var(--text);
        border: 1px solid var(--line);
      }

      .button.secondary:hover {
        background: var(--acid);
        color: #050608;
        border-color: var(--acid);
      }

      .catalogue-preview-player {
        position: fixed;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: 1001;
        width: 100%;
        height: 114px;
        overflow: hidden;
        transform: translateY(100%);
        background: #000;
        border-top: 1px solid rgba(216, 255, 62, 0.16);
        box-shadow: 0 -10px 44px rgba(0, 0, 0, 0.48);
        opacity: 0;
        pointer-events: none;
        transition:
          opacity 0.22s ease,
          transform 0.22s ease;
      }

      .catalogue-preview-player.is-visible {
        opacity: 1;
        pointer-events: auto;
        transform: translateY(0);
      }

      .catalogue-preview-frame {
        width: 100%;
        height: 114px;
        background: #000;
        overflow: hidden;
      }

      .catalogue-preview-frame iframe {
        display: block;
        width: 100%;
        height: 162px;
        border: 0;
        background: #000;
      }

      .catalogue-preview-frame.is-juno iframe {
        height: 255px;
      }

      footer {
        max-width: 1080px;
        margin: 80px auto 0;
        color: var(--muted);
        font-size: 12px;
        padding-top: 28px;
        border-top: 1px solid var(--line);
        display: flex;
        justify-content: space-between;
        gap: 20px;
      }

      @media (max-width: 980px) {
        body.beatport-preview-visible .page {
          padding-bottom: 162px;
        }

        .release {
          grid-template-columns: 62px 44px 1fr;
          gap: 12px;
        }

        .label {
          grid-column: 3;
          padding-top: 0;
        }

        .release-actions {
          grid-column: 3;
          justify-content: flex-start;
          margin-top: 4px;
        }

        .store-links {
          justify-content: flex-start;
        }

        .catalogue-preview-player {
          height: 162px;
        }

        .catalogue-preview-frame {
          height: 162px;
        }

        .catalogue-preview-frame iframe {
          height: 162px;
        }

        .catalogue-preview-frame.is-juno iframe {
          height: 255px;
        }
      }

      @media (max-width: 860px) {
        .page {
          padding: 22px;
        }

        header {
          align-items: flex-start;
          flex-direction: column;
        }

        nav {
          flex-wrap: wrap;
        }

        footer {
          flex-direction: column;
        }
      }

      @media (max-width: 520px) {
        .release {
          grid-template-columns: 1fr;
          gap: 10px;
        }

        .year,
        .label,
        .release-actions {
          grid-column: auto;
        }

        .year {
          padding-top: 0;
        }

        .play-cell {
          order: -1;
        }

        .catalogue-links {
          flex-direction: column;
          align-items: flex-start;
        }

        .button {
          width: 100%;
          text-align: center;
        }
      }
    </style>
  </head>

  <body>
    <div class="page">
      <header>
        <a class="logo" href="/" aria-label="Itchy Lemon homepage">
          <img class="logo-icon" src="/favicon.png" alt="" />
          <span>Itchy Lemon</span>
        </a>

        <nav>
          <a href="/music">Music</a>
          <a href="/bio">Bio</a>
          <a class="active" href="/discography">Discography</a>
          <a href="/media">Media</a>
          <a href="/press-kit">Press Kit</a>
          <a href="/sets">Sets</a>
          <a href="/booking">Booking</a>
        </nav>
      </header>

      <main>
        <p class="eyebrow">Selected Catalogue</p>

        <h1>Discography</h1>

        <p class="lead">
          A working catalogue selection of Itchy Lemon releases across Beatport, Traxsource, Juno Download, Amazon Music and Apple Music. This list can be refined later into a final curated discography.
        </p>

        <section class="release-list">
          {releases.map((release) => (
            <article class="release">
              <div class="year">{release.year}</div>

              <div class="play-cell">
                {release.preview ? (
                  <button
                    class="preview-button"
                    type="button"
                    data-preview-type={release.preview.type}
                    data-preview-id={release.preview.id}
                    data-preview-url={release.preview.url}
                    data-preview-height={release.preview.height}
                    aria-label={`Play preview of ${release.title}`}
                    title={`Play preview of ${release.title}`}
                  >
                    <span>▶</span>
                  </button>
                ) : (
                  <span class="no-preview" aria-hidden="true"></span>
                )}
              </div>

              <div>
                <h2>{release.title}</h2>
                <p>{release.description}</p>
              </div>

              <div class="label">{release.label}</div>

              <div class="release-actions">
                <div class="store-links" aria-label={`Buy ${release.title}`}>
                  {release.stores.map((store) => (
                    <a
                      class="store-link"
                      href={store.url}
                      target="_blank"
                      rel="noreferrer"
                    >
                      {store.label}
                    </a>
                  ))}
                </div>
              </div>
            </article>
          ))}
        </section>

        <section class="catalogue-card">
          <div>
            <h2>Full Catalogue</h2>
            <p>
              Explore the complete Itchy Lemon catalogue across the main electronic music stores and streaming platforms where releases are available.
            </p>
          </div>

          <div class="catalogue-links" aria-label="Full catalogue links">
            {fullCatalogueLinks.map((store, index) => (
              <a
                class={index === 0 ? "button" : "button secondary"}
                href={store.url}
                target="_blank"
                rel="noreferrer"
              >
                {store.label}
              </a>
            ))}
          </div>
        </section>
      </main>

      <footer>
        <span>© 2026 Itchy Lemon. All rights reserved.</span>
        <span>
          Selected releases · Beatport · Traxsource · Juno Download · Amazon Music · Apple Music ·
          <a href="/privacy-policy">Privacy Policy</a>
        </span>
      </footer>
    </div>

    <div class="catalogue-preview-player" data-catalogue-player aria-label="Catalogue preview player">
      <div class="catalogue-preview-frame" data-catalogue-frame></div>
    </div>

    <script>
      const cataloguePlayer = document.querySelector("[data-catalogue-player]");
      const catalogueFrame = document.querySelector("[data-catalogue-frame]");
      const previewButtons = document.querySelectorAll("[data-preview-type]");

      const resetActivePreviewButtons = () => {
        previewButtons.forEach((button) => {
          button.classList.remove("is-active");
        });
      };

      const resetPlayerType = () => {
        catalogueFrame?.classList.remove("is-juno");
      };

      const hideCataloguePlayer = () => {
        cataloguePlayer?.classList.remove("is-visible");
        document.body.classList.remove("beatport-preview-visible");
        resetPlayerType();

        if (catalogueFrame) {
          catalogueFrame.innerHTML = "";
        }

        resetActivePreviewButtons();
      };

      const showCataloguePlayer = (button) => {
        const previewType = button.getAttribute("data-preview-type");
        const previewId = button.getAttribute("data-preview-id");
        const previewUrl = button.getAttribute("data-preview-url");
        const previewHeight = button.getAttribute("data-preview-height") || "162";

        document.dispatchEvent(new CustomEvent("itchy-lemon-close-mixcloud-player"));

        resetActivePreviewButtons();
        resetPlayerType();

        button.classList.add("is-active");

        if (previewType === "beatport" && previewId) {
          catalogueFrame.innerHTML = `
            <iframe
              src="https://embed.beatport.com/?id=${previewId}&type=track"
              width="100%"
              height="162"
              frameborder="0"
              scrolling="no"
              title="Beatport preview player"
            ></iframe>
          `;
        }

        if (previewType === "juno" && previewUrl) {
          catalogueFrame?.classList.add("is-juno");

          catalogueFrame.innerHTML = `
            <iframe
              src="${previewUrl}"
              width="100%"
              height="${previewHeight}"
              frameborder="no"
              scrolling="no"
              title="Juno Download preview player"
            ></iframe>
          `;
        }

        cataloguePlayer?.classList.add("is-visible");
        document.body.classList.add("beatport-preview-visible");
      };

      previewButtons.forEach((button) => {
        button.addEventListener("click", (event) => {
          event.stopPropagation();
          showCataloguePlayer(button);
        });
      });

      cataloguePlayer?.addEventListener("click", (event) => {
        event.stopPropagation();
      });

      document.addEventListener("click", () => {
        if (cataloguePlayer?.classList.contains("is-visible")) {
          hideCataloguePlayer();
        }
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          hideCataloguePlayer();
        }
      });
    </script>

    <GlobalMixcloudPlayer />
    <HubSpotTracking />
  </body>
</html>