<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Discography and selected Beatport catalogue by Itchy Lemon — Portuguese DJ and electronic music producer."
    />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Discography | Itchy Lemon</title>
    <link rel="icon" type="image/png" href="/favicon.png" />

    <style>
      :root {
        --bg: #07090c;
        --bg-soft: #10141b;
        --text: #f4f4f0;
        --muted: #a7adb8;
        --acid: #d8ff3e;
        --line: rgba(255, 255, 255, 0.12);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: Arial, Helvetica, sans-serif;
        background:
          radial-gradient(circle at top right, rgba(216, 255, 62, 0.12), transparent 34%),
          linear-gradient(135deg, #07090c 0%, #111827 48%, #050608 100%);
        color: var(--text);
        min-height: 100vh;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .page {
        min-height: 100vh;
        padding: 32px;
      }

      header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 24px;
        padding-bottom: 56px;
      }

      .logo {
        font-size: 14px;
        letter-spacing: 0.32em;
        text-transform: uppercase;
        color: var(--acid);
        font-weight: 700;
      }

      nav {
        display: flex;
        gap: 22px;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--muted);
      }

      nav a:hover,
      nav a.active {
        color: var(--acid);
      }

      main {
        max-width: 1080px;
        margin: 0 auto;
      }

      .eyebrow {
        color: var(--acid);
        text-transform: uppercase;
        letter-spacing: 0.24em;
        font-size: 13px;
        margin-bottom: 18px;
      }

      h1 {
        margin: 0;
        font-size: clamp(48px, 8vw, 104px);
        line-height: 0.9;
        letter-spacing: -0.06em;
        text-transform: uppercase;
      }

      .lead {
        margin-top: 32px;
        max-width: 840px;
        font-size: clamp(22px, 3vw, 34px);
        line-height: 1.16;
      }

      .section-title {
        margin: 72px 0 22px;
        color: var(--acid);
        font-size: 13px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }

      .release-list {
        display: grid;
        gap: 0;
      }

      .release {
        display: grid;
        grid-template-columns: 80px 1fr 160px 110px 130px;
        gap: 22px;
        align-items: start;
        border-top: 1px solid var(--line);
        padding: 24px 0;
      }

      .year {
        color: var(--acid);
        font-size: 14px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }

      .release h2 {
        margin: 0;
        font-size: 26px;
        line-height: 1.05;
        letter-spacing: -0.04em;
      }

      .release p {
        margin: 9px 0 0;
        color: var(--muted);
        font-size: 15px;
        line-height: 1.55;
      }

      .label,
      .type {
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.14em;
        font-size: 12px;
        line-height: 1.45;
      }

      .type {
        text-align: right;
      }

      .listen {
        justify-self: end;
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 9px 13px;
        color: var(--muted);
        font-size: 11px;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        white-space: nowrap;
        transition: 0.2s ease;
      }

      .listen:hover {
        color: #050608;
        background: var(--acid);
        border-color: var(--acid);
        transform: translateY(-2px);
      }

      .catalogue-card {
        margin-top: 48px;
        border: 1px solid var(--line);
        background: rgba(16, 20, 27, 0.72);
        border-radius: 28px;
        padding: 28px;
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 24px;
        align-items: center;
        backdrop-filter: blur(12px);
      }

      .catalogue-card h2 {
        margin: 0;
        font-size: 30px;
        letter-spacing: -0.04em;
      }

      .catalogue-card p {
        margin: 12px 0 0;
        color: var(--muted);
        font-size: 16px;
        line-height: 1.6;
      }

      .button {
        display: inline-block;
        background: var(--acid);
        color: #050608;
        border-radius: 999px;
        padding: 15px 22px;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        white-space: nowrap;
      }

      footer {
        max-width: 1080px;
        margin: 80px auto 0;
        color: var(--muted);
        font-size: 12px;
        padding-top: 28px;
        border-top: 1px solid var(--line);
        display: flex;
        justify-content: space-between;
        gap: 20px;
      }

      @media (max-width: 980px) {
        .release {
          grid-template-columns: 1fr;
          gap: 10px;
        }

        .type {
          text-align: left;
        }

        .listen {
          justify-self: start;
          margin-top: 4px;
        }

        .catalogue-card {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 860px) {
        .page {
          padding: 22px;
        }

        header {
          align-items: flex-start;
          flex-direction: column;
        }

        nav {
          flex-wrap: wrap;
        }

        footer {
          flex-direction: column;
        }
      }
    </style>
  </head>

