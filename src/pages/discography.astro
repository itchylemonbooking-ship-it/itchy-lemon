---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Discography of Itchy Lemon — selected electronic music releases from Beatport, Traxsource, Amazon Music, Apple Music and Spotify."
    />
    <meta name="author" content="Itchy Lemon" />
    <meta name="theme-color" content="#07090c" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Discography | Itchy Lemon</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href="https://itchy-lemon.pages.dev/discography/" />

    <style>
      :root {
        --bg: #07090c;
        --bg-soft: #10141b;
        --text: #f4f4f0;
        --muted: #a7adb8;
        --acid: #d8ff3e;
        --line: rgba(255, 255, 255, 0.12);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: Arial, Helvetica, sans-serif;
        background:
          radial-gradient(circle at top right, rgba(216, 255, 62, 0.12), transparent 34%),
          linear-gradient(135deg, #07090c 0%, #111827 48%, #050608 100%);
        color: var(--text);
        min-height: 100vh;
      }

      body.catalogue-player-visible .page {
        padding-bottom: 114px;
      }

      body.catalogue-player-visible.catalogue-player-traxsource .page {
        padding-bottom: 240px;
      }

      body.catalogue-player-visible #hubspot-messages-iframe-container {
        bottom: 122px !important;
        z-index: 2147483001 !important;
      }

      body.catalogue-player-visible.catalogue-player-traxsource #hubspot-messages-iframe-container {
        bottom: 248px !important;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .page {
        min-height: 100vh;
        padding: 32px;
      }

      main {
        max-width: 1080px;
        margin: 0 auto;
      }

      .eyebrow {
        color: var(--acid);
        text-transform: uppercase;
        letter-spacing: 0.24em;
        font-size: 13px;
        margin-bottom: 18px;
      }

      h1 {
        margin: 0;
        font-size: clamp(48px, 8vw, 104px);
        line-height: 0.9;
        letter-spacing: -0.06em;
        text-transform: uppercase;
      }

      .lead {
        margin-top: 32px;
        max-width: 780px;
        font-size: clamp(22px, 3vw, 34px);
        line-height: 1.16;
        color: var(--text);
      }

      .release-list {
        display: grid;
        gap: 0;
        margin-top: 64px;
      }

      .release {
        display: grid;
        grid-template-columns: 80px 44px 1fr 180px 260px;
        gap: 18px;
        align-items: start;
        border-top: 1px solid var(--line);
        padding: 24px 0;
      }

      .year {
        color: var(--acid);
        font-size: 14px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        padding-top: 8px;
      }

      .play-cell {
        display: flex;
        justify-content: flex-start;
        align-items: flex-start;
      }

      .release h2 {
        margin: 0;
        font-size: 26px;
        line-height: 1.05;
        letter-spacing: -0.04em;
      }

      .release p {
        margin: 9px 0 0;
        color: var(--muted);
        font-size: 15px;
        line-height: 1.55;
      }

      .label {
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.14em;
        font-size: 12px;
        line-height: 1.45;
        padding-top: 8px;
      }

      .release-actions {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        align-items: flex-start;
        flex-wrap: wrap;
      }

      .store-links {
        display: flex;
        justify-content: flex-end;
        gap: 8px;
        align-items: center;
        flex-wrap: wrap;
      }

      .store-link,
      .listen-button {
        border: 1px solid var(--line);
        color: var(--muted);
        background: transparent;
        font-family: inherit;
        cursor: pointer;
        transition: 0.2s ease;
      }

      .store-link {
        border-radius: 999px;
        padding: 9px 12px;
        font-size: 10px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        white-space: nowrap;
      }

      .listen-button {
        width: 34px;
        height: 34px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        padding: 0;
        color: var(--acid);
        font-size: 13px;
        line-height: 1;
        flex-shrink: 0;
      }

      .listen-button span {
        display: block;
        transform: translateX(1px);
      }

      .store-link:hover,
      .listen-button:hover,
      .listen-button.is-active {
        color: #050608;
        background: var(--acid);
        border-color: var(--acid);
        transform: translateY(-2px);
      }

      .listen-button:hover span,
      .listen-button.is-active span {
        color: #050608;
      }

      .no-preview {
        width: 34px;
        height: 34px;
      }

      .catalogue-card {
        margin-top: 48px;
        border: 1px solid var(--line);
        background: rgba(16, 20, 27, 0.72);
        border-radius: 28px;
        padding: 28px;
        display: grid;
        grid-template-columns: 1fr;
        gap: 24px;
        align-items: center;
        backdrop-filter: blur(12px);
      }

      .catalogue-card h2 {
        margin: 0;
        font-size: 30px;
        letter-spacing: -0.04em;
      }

      .catalogue-card p {
        margin: 12px 0 0;
        color: var(--muted);
        font-size: 16px;
        line-height: 1.6;
      }

      .catalogue-links {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }

      .button {
        display: inline-block;
        background: var(--acid);
        color: #050608;
        border-radius: 999px;
        padding: 15px 22px;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        white-space: nowrap;
      }

      .button.secondary {
        background: transparent;
        color: var(--text);
        border: 1px solid var(--line);
      }

      .button.secondary:hover {
        background: var(--acid);
        color: #050608;
        border-color: var(--acid);
      }

      .catalogue-preview-player {
        position: fixed;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: 2147483000;
        width: 100%;
        height: 114px;
        overflow: hidden;
        transform: translateY(100%);
        background: #000;
        border-top: 1px solid rgba(216, 255, 62, 0.16);
        box-shadow: 0 -10px 44px rgba(0, 0, 0, 0.48);
        opacity: 0;
        pointer-events: none;
        transition:
          opacity 0.22s ease,
          transform 0.22s ease,
          height 0.22s ease;
      }

      body.catalogue-player-traxsource .catalogue-preview-player {
        height: 240px;
      }

      .catalogue-preview-player.is-visible {
        opacity: 1;
        pointer-events: auto;
        transform: translateY(0);
      }

      .catalogue-preview-frame {
        width: 100%;
        height: 114px;
        background: #000;
        overflow: hidden;
      }

      body.catalogue-player-traxsource .catalogue-preview-frame {
        height: 240px;
      }

      .catalogue-preview-frame iframe {
        display: block;
        width: 100%;
        border: 0;
        background: #000;
      }

      .catalogue-preview-frame.is-spotify {
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .catalogue-preview-frame.is-spotify iframe {
        height: 80px;
        border-radius: 12px;
      }

      .catalogue-preview-frame.is-beatport {
        display: block;
      }

      .catalogue-preview-frame.is-beatport iframe {
        height: 162px;
      }

      .catalogue-preview-frame.is-traxsource {
        display: block;
        height: 240px;
      }

      .catalogue-preview-frame.is-traxsource iframe {
        width: 100%;
        height: 240px;
        transform: none;
      }

      footer {
        max-width: 1080px;
        margin: 80px auto 0;
        color: var(--muted);
        font-size: 12px;
        padding-top: 28px;
        border-top: 1px solid var(--line);
        display: flex;
        justify-content: space-between;
        gap: 20px;
      }

      footer a {
        color: var(--muted);
      }

      footer a:hover {
        color: var(--acid);
      }

      @media (max-width: 1024px) {
        .page {
          padding: 22px;
        }

        footer {
          flex-direction: column;
        }
      }

      @media (max-width: 980px) {
        body.catalogue-player-visible .page {
          padding-bottom: 114px;
        }

        body.catalogue-player-visible.catalogue-player-traxsource .page {
          padding-bottom: 240px;
        }

        body.catalogue-player-visible #hubspot-messages-iframe-container {
          bottom: 122px !important;
          z-index: 2147483001 !important;
        }

        body.catalogue-player-visible.catalogue-player-traxsource #hubspot-messages-iframe-container {
          bottom: 248px !important;
        }

        .release {
          grid-template-columns: 62px 44px 1fr;
          gap: 12px;
        }

        .label {
          grid-column: 3;
          padding-top: 0;
        }

        .release-actions {
          grid-column: 3;
          justify-content: flex-start;
          margin-top: 4px;
        }

        .store-links {
          justify-content: flex-start;
        }
      }

      @media (max-width: 520px) {
        .release {
          grid-template-columns: 1fr;
          gap: 10px;
        }

        .year,
        .label,
        .release-actions {
          grid-column: auto;
        }

        .year {
          padding-top: 0;
        }

        .play-cell {
          order: -1;
        }

        .catalogue-links {
          flex-direction: column;
          align-items: flex-start;
        }

        .button {
          width: 100%;
          text-align: center;
        }
      }
    </style>
  </head>

  <body>
    <div class="page">
      <SiteHeader activePage="discography" />

      <main>
        <p class="eyebrow">Selected Catalogue</p>

        <h1>Discography</h1>

        <p class="lead">
          A working catalogue selection of Itchy Lemon releases across Beatport, Traxsource, Amazon Music, Apple Music and Spotify. This list can be refined later into a final curated discography.
        </p>

        <section class="release-list">
          {releases.map((release) => (
            <article class="release">
              <div class="year">{release.year}</div>

              <div class="play-cell">
                {release.spotifyEmbedUrl || release.beatportPreviewId || release.traxsourcePreviewId ? (
                  <button
                    class="listen-button"
                    type="button"
                    data-player-type={
                      release.spotifyEmbedUrl
                        ? "spotify"
                        : release.beatportPreviewId
                          ? "beatport"
                          : "traxsource"
                    }
                    data-spotify-embed-url={release.spotifyEmbedUrl}
                    data-beatport-preview-id={release.beatportPreviewId}
                    data-traxsource-preview-id={release.traxsourcePreviewId}
                    aria-label={`Listen to ${release.title}`}
                    title={`Listen to ${release.title}`}
                  >
                    <span>▶</span>
                  </button>
                ) : (
                  <span class="no-preview" aria-hidden="true"></span>
                )}
              </div>

              <div>
                <h2>{release.title}</h2>
                <p>{release.description}</p>
              </div>

              <div class="label">{release.label}</div>

              <div class="release-actions">
                <div class="store-links" aria-label={`Buy or download ${release.title}`}>
                  {release.stores.map((store) => (
                    <a
                      class="store-link"
                      href={store.url}
                      target="_blank"
                      rel="noreferrer"
                    >
                      {store.label}
                    </a>
                  ))}
                </div>
              </div>
            </article>
          ))}
        </section>

        <section class="catalogue-card">
          <div>
            <h2>Full Catalogue</h2>
            <p>
              Explore the complete Itchy Lemon catalogue across the main electronic music stores and streaming platforms where releases are available.
            </p>
          </div>

          <div class="catalogue-links" aria-label="Full catalogue links">
            {fullCatalogueLinks.map((store, index) => (
              <a
                class={index === 0 ? "button" : "button secondary"}
                href={store.url}
                target="_blank"
                rel="noreferrer"
              >
                {store.label}
              </a>
            ))}
          </div>
        </section>
      </main>

      <footer>
        <span>© 2026 Itchy Lemon. All rights reserved.</span>
        <span>
          Selected releases · Beatport · Traxsource · Amazon Music · Apple Music · Spotify ·
          <a href="/privacy-policy">Privacy Policy</a>
        </span>
      </footer>
    </div>

    <div class="catalogue-preview-player" data-catalogue-player aria-label="Catalogue player">
      <div class="catalogue-preview-frame" data-catalogue-frame></div>
    </div>

    <script>
      const cataloguePlayer = document.querySelector("[data-catalogue-player]");
      const catalogueFrame = document.querySelector("[data-catalogue-frame]");
      const listenButtons = document.querySelectorAll("[data-player-type]");

      const resetActiveListenButtons = () => {
        listenButtons.forEach((button) => {
          button.classList.remove("is-active");
        });
      };

      const resetPlayerFrameClass = () => {
        catalogueFrame?.classList.remove("is-spotify");
        catalogueFrame?.classList.remove("is-beatport");
        catalogueFrame?.classList.remove("is-traxsource");
        document.body.classList.remove("catalogue-player-traxsource");
      };

      const getHubSpotChatContainer = () => {
        return document.querySelector("#hubspot-messages-iframe-container");
      };

      const moveHubSpotChatAbovePlayer = () => {
        const hubSpotChat = getHubSpotChatContainer();

        if (!hubSpotChat) {
          return;
        }

        const isTraxsource = document.body.classList.contains("catalogue-player-traxsource");
        const bottomOffset = isTraxsource ? "248px" : "122px";

        if (!hubSpotChat.dataset.originalBottom) {
          hubSpotChat.dataset.originalBottom = hubSpotChat.style.bottom || "";
        }

        if (!hubSpotChat.dataset.originalZIndex) {
          hubSpotChat.dataset.originalZIndex = hubSpotChat.style.zIndex || "";
        }

        hubSpotChat.style.setProperty("bottom", bottomOffset, "important");
        hubSpotChat.style.setProperty("z-index", "2147483001", "important");
      };

      const resetHubSpotChatPosition = () => {
        const hubSpotChat = getHubSpotChatContainer();

        if (!hubSpotChat) {
          return;
        }

        if (hubSpotChat.dataset.originalBottom) {
          hubSpotChat.style.setProperty("bottom", hubSpotChat.dataset.originalBottom);
        } else {
          hubSpotChat.style.removeProperty("bottom");
        }

        if (hubSpotChat.dataset.originalZIndex) {
          hubSpotChat.style.setProperty("z-index", hubSpotChat.dataset.originalZIndex);
        } else {
          hubSpotChat.style.removeProperty("z-index");
        }

        delete hubSpotChat.dataset.originalBottom;
        delete hubSpotChat.dataset.originalZIndex;
      };

      const hideCataloguePlayer = () => {
        cataloguePlayer?.classList.remove("is-visible");
        document.body.classList.remove("catalogue-player-visible");

        if (catalogueFrame) {
          catalogueFrame.innerHTML = "";
        }

        resetPlayerFrameClass();
        resetActiveListenButtons();
        resetHubSpotChatPosition();
      };

      const showCataloguePlayer = (button) => {
        const playerType = button.getAttribute("data-player-type");
        const spotifyEmbedUrl = button.getAttribute("data-spotify-embed-url");
        const beatportPreviewId = button.getAttribute("data-beatport-preview-id");
        const traxsourcePreviewId = button.getAttribute("data-traxsource-preview-id");

        document.dispatchEvent(new CustomEvent("itchy-lemon-close-mixcloud-player"));

        resetActiveListenButtons();
        resetPlayerFrameClass();

        button.classList.add("is-active");

        if (playerType === "spotify" && spotifyEmbedUrl && catalogueFrame) {
          catalogueFrame.classList.add("is-spotify");

          catalogueFrame.innerHTML = `
            <iframe
              src="${spotifyEmbedUrl}"
              width="100%"
              height="80"
              frameborder="0"
              allowfullscreen
              allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
              loading="lazy"
              title="Spotify player"
            ></iframe>
          `;
        }

        if (playerType === "beatport" && beatportPreviewId && catalogueFrame) {
          catalogueFrame.classList.add("is-beatport");

          catalogueFrame.innerHTML = `
            <iframe
              src="https://embed.beatport.com/?id=${beatportPreviewId}&type=track"
              width="100%"
              height="162"
              frameborder="0"
              scrolling="no"
              title="Beatport preview player"
            ></iframe>
          `;
        }

        if (playerType === "traxsource" && traxsourcePreviewId && catalogueFrame) {
          document.body.classList.add("catalogue-player-traxsource");
          catalogueFrame.classList.add("is-traxsource");

          catalogueFrame.innerHTML = `
            <iframe
              src="https://embed.traxsource.com/player/track/${traxsourcePreviewId}"
              width="100%"
              height="240"
              frameborder="0"
              scrolling="no"
              title="Traxsource preview player"
            ></iframe>
          `;
        }

        cataloguePlayer?.classList.add("is-visible");
        document.body.classList.add("catalogue-player-visible");

        moveHubSpotChatAbovePlayer();

        setTimeout(moveHubSpotChatAbovePlayer, 250);
        setTimeout(moveHubSpotChatAbovePlayer, 750);
        setTimeout(moveHubSpotChatAbovePlayer, 1500);
      };

      listenButtons.forEach((button) => {
        button.addEventListener("click", (event) => {
          event.stopPropagation();
          showCataloguePlayer(button);
        });
      });

      cataloguePlayer?.addEventListener("click", (event) => {
        event.stopPropagation();
      });

      document.addEventListener("click", () => {
        if (cataloguePlayer?.classList.contains("is-visible")) {
          hideCataloguePlayer();
        }
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          hideCataloguePlayer();
        }
      });
    </script>

    <GlobalMixcloudPlayer />
    <HubSpotTracking />
  </body>
</html>