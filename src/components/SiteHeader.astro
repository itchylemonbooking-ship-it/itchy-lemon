---
interface Props {
  activePage?: "music" | "bio" | "discography" | "media" | "press-kit" | "sets" | "booking" | "store";
}

const { activePage } = Astro.props;

const navItems = [
  { key: "music", label: "Music", href: "/music" },
  { key: "bio", label: "Bio", href: "/bio" },
  { key: "discography", label: "Discography", href: "/discography" },
  { key: "media", label: "Media", href: "/media" },
  { key: "press-kit", label: "Press Kit", href: "/press-kit" },
  { key: "sets", label: "Sets", href: "/sets" },
  { key: "booking", label: "Booking", href: "/booking" },
];
---

<header class="site-header">
  <a class="logo" href="/" aria-label="Itchy Lemon homepage">
    <img class="logo-icon" src="/favicon.png" alt="" />
    <span>Itchy Lemon</span>
  </a>

  <button
    class="mobile-menu-toggle"
    type="button"
    aria-label="Open navigation menu"
    aria-expanded="false"
    data-site-mobile-menu-toggle
  >
    <span class="menu-icon" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </span>
    Menu
  </button>

  <nav class="site-nav" data-site-mobile-menu aria-label="Main navigation">
    {navItems.map((item) => (
      <a
        class:list={[{ active: activePage === item.key }]}
        href={item.href}
      >
        {item.label}
      </a>
    ))}
  </nav>
</header>

<style>
  .site-header {
    position: relative;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    padding-bottom: 56px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--acid);
    font-weight: 700;
    text-transform: uppercase;
    white-space: nowrap;
    text-decoration: none;
    z-index: 3;
  }

  .logo-icon {
    display: block;
    width: 22px;
    height: 22px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .logo span {
    display: inline-block;
    font-size: 14px;
    letter-spacing: 0.32em;
    line-height: 1;
  }

  .site-nav {
    display: flex;
    gap: 22px;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
  }

  .site-nav a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .site-nav a:hover,
  .site-nav a.active {
    color: var(--acid);
  }

  .mobile-menu-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    gap: 10px;
    min-height: 42px;
    padding: 0 16px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(16, 20, 27, 0.78);
    color: var(--text);
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 12px;
    font-weight: 700;
    z-index: 3;
    transition:
      border-color 0.2s ease,
      background 0.2s ease,
      color 0.2s ease;
  }

  .mobile-menu-toggle:hover,
  .mobile-menu-toggle.is-open {
    border-color: var(--acid);
    color: var(--acid);
    background: rgba(216, 255, 62, 0.08);
  }

  .menu-icon {
    position: relative;
    width: 18px;
    height: 12px;
    display: inline-block;
  }

  .menu-icon span {
    position: absolute;
    left: 0;
    width: 18px;
    height: 2px;
    border-radius: 999px;
    background: currentColor;
    transition:
      transform 0.2s ease,
      opacity 0.2s ease,
      top 0.2s ease;
  }

  .menu-icon span:nth-child(1) {
    top: 0;
  }

  .menu-icon span:nth-child(2) {
    top: 5px;
  }

  .menu-icon span:nth-child(3) {
    top: 10px;
  }

  .mobile-menu-toggle.is-open .menu-icon span:nth-child(1) {
    top: 5px;
    transform: rotate(45deg);
  }

  .mobile-menu-toggle.is-open .menu-icon span:nth-child(2) {
    opacity: 0;
  }

  .mobile-menu-toggle.is-open .menu-icon span:nth-child(3) {
    top: 5px;
    transform: rotate(-45deg);
  }

  @media (max-width: 1024px) {
    .site-header {
      align-items: center;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 16px;
      padding-bottom: 48px;
    }

    .logo span {
      font-size: 13px;
      letter-spacing: 0.26em;
    }

    .mobile-menu-toggle {
      display: inline-flex;
      margin-left: auto;
    }

    .site-nav {
      width: 100%;
      max-height: 0;
      overflow: hidden;
      display: grid;
      grid-template-columns: 1fr;
      gap: 0;
      padding: 0;
      border: 0;
      border-radius: 24px;
      background: rgba(16, 20, 27, 0.92);
      backdrop-filter: blur(14px);
      opacity: 0;
      transform: translateY(-8px);
      transition:
        max-height 0.25s ease,
        opacity 0.2s ease,
        transform 0.2s ease,
        padding 0.2s ease,
        border-color 0.2s ease;
    }

    .site-nav.is-open {
      max-height: 520px;
      opacity: 1;
      transform: translateY(0);
      padding: 10px;
      border: 1px solid var(--line);
    }

    .site-nav a {
      display: flex;
      align-items: center;
      justify-content: space-between;
      min-height: 46px;
      padding: 0 14px;
      border-radius: 16px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      font-size: 13px;
      letter-spacing: 0.16em;
    }

    .site-nav a:last-child {
      border-bottom: 0;
    }

    .site-nav a::after {
      content: "›";
      color: var(--acid);
      opacity: 0.65;
      font-size: 20px;
      line-height: 1;
    }

    .site-nav a:hover,
    .site-nav a.active {
      background: rgba(216, 255, 62, 0.08);
    }
  }
</style>

<script>
  const mobileMenuToggle = document.querySelector("[data-site-mobile-menu-toggle]");
  const mobileMenu = document.querySelector("[data-site-mobile-menu]");

  mobileMenuToggle?.addEventListener("click", () => {
    const isOpen = mobileMenu?.classList.toggle("is-open");

    mobileMenuToggle.classList.toggle("is-open", isOpen);
    mobileMenuToggle.setAttribute("aria-expanded", String(isOpen));
    mobileMenuToggle.setAttribute(
      "aria-label",
      isOpen ? "Close navigation menu" : "Open navigation menu"
    );
  });

  mobileMenu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu.classList.remove("is-open");
      mobileMenuToggle?.classList.remove("is-open");
      mobileMenuToggle?.setAttribute("aria-expanded", "false");
      mobileMenuToggle?.setAttribute("aria-label", "Open navigation menu");
    });
  });
</script>